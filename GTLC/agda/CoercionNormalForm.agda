module CoercionNormalForm where

open import Data.Product using (ОЈ-syntax; вҲғ-syntax; _Г—_; _,_)
open import Data.Sum using (_вҠҺ_; injвӮҒ; injвӮӮ)
open import Relation.Binary.PropositionalEquality using (_вүЎ_; refl; cong; congвӮӮ)

open import Types
open import CoercionReduction

infix 7 _вҶЈ_
infix 5 _iвЁҹs_
infix 5 _gвЁҹi_
infix 5 _gвЁҹg_
infix 4 _вҮЁвҒҝ_ _вҮЁвҒұ_ _вҮЁбөҚ_
infix 7 _?вҒҝ_ _!вҒҝ_
infix 6 _?вҒҝ_вЁҫ_ _?вҒҝ_вЁҫ! _?вҒҝ_вЁҫ_вЁҫ! вҖ№_вҖә_вЁҫ_!вҒҝ

mutual
  data _вҮЁвҒҝ_ : Ty вҶ’ Ty вҶ’ Set
  data _вҮЁвҒұ_ : Ty вҶ’ Ty вҶ’ Set
  data _вҮЁбөҚ_ : Ty вҶ’ Ty вҶ’ Set

  data _вҮЁвҒҝ_ where
    idвҒҝ : (A : Ty)
      вҶ’ A вҮЁвҒҝ A
    _?вҒҝ_ : вҲҖ (G : Ty)
      вҶ’ Ground G
      вҶ’ вҳ… вҮЁвҒҝ G
    _?вҒҝ_вЁҫ_ : вҲҖ (G : Ty) {B}
      вҶ’ Ground G
      вҶ’ G вҮЁвҒұ B
      вҶ’ вҳ… вҮЁвҒҝ B
    _?вҒҝ_вЁҫ! : вҲҖ (G : Ty)
      вҶ’ Ground G
      вҶ’ вҳ… вҮЁвҒҝ вҳ…
    _?вҒҝ_вЁҫ_вЁҫ! : вҲҖ (G : Ty)
      вҶ’ Ground G
      вҶ’ G вҮЁбөҚ G
      вҶ’ вҳ… вҮЁвҒҝ вҳ…
    вҖІ_ : вҲҖ {A B}
      вҶ’ A вҮЁвҒұ B
      вҶ’ A вҮЁвҒҝ B

  data _вҮЁвҒұ_ where
    _!вҒҝ_ : вҲҖ (G : Ty)
      вҶ’ Ground G
      вҶ’ G вҮЁвҒұ вҳ…
    вҖ№_вҖә_вЁҫ_!вҒҝ : вҲҖ {A} (G : Ty)
      вҶ’ A вҮЁбөҚ G
      вҶ’ Ground G
      вҶ’ A вҮЁвҒұ вҳ…
    пјҮ_ : вҲҖ {A B}
      вҶ’ A вҮЁбөҚ B
      вҶ’ A вҮЁвҒұ B
    вҠҘвҒҝ_вҮЁ_ : вҲҖ (A B : Ty)
      вҶ’ A вҮЁвҒұ B

  data _вҮЁбөҚ_ where
    _вҶЈ_ : вҲҖ {A B C D}
      вҶ’ C вҮЁвҒҝ A
      вҶ’ B вҮЁвҒҝ D
      вҶ’ (A вҮ’ B) вҮЁбөҚ (C вҮ’ D)

mutual
  вҢҠ_вҢӢЛў : вҲҖ {A B}
    вҶ’ A вҮЁвҒҝ B
    вҶ’ Coercion
  вҢҠ_вҢӢвҒұ : вҲҖ {A B}
    вҶ’ A вҮЁвҒұ B
    вҶ’ Coercion
  вҢҠ_вҢӢбөҚ : вҲҖ {A B}
    вҶ’ A вҮЁбөҚ B
    вҶ’ Coercion

  вҢҠ idвҒҝ A вҢӢЛў = idб¶ң A
  вҢҠ G ?вҒҝ _ вҢӢЛў = G `?
  вҢҠ G ?вҒҝ _ вЁҫ i вҢӢЛў = G `? вЁҹ вҢҠ i вҢӢвҒұ
  вҢҠ G ?вҒҝ _ вЁҫ! вҢӢЛў = G `? вЁҹ G !
  вҢҠ G ?вҒҝ _ вЁҫ g вЁҫ! вҢӢЛў = (G `? вЁҹ вҢҠ g вҢӢбөҚ) вЁҹ G !
  вҢҠ вҖІ i вҢӢЛў = вҢҠ i вҢӢвҒұ

  вҢҠ G !вҒҝ _ вҢӢвҒұ = G !
  вҢҠ вҖ№ G вҖә g вЁҫ _ !вҒҝ вҢӢвҒұ = вҢҠ g вҢӢбөҚ вЁҹ G !
  вҢҠ пјҮ g вҢӢвҒұ = вҢҠ g вҢӢбөҚ
  вҢҠ вҠҘвҒҝ A вҮЁ B вҢӢвҒұ = вҠҘб¶ң A вҮЁ B

  вҢҠ c вҶЈ d вҢӢбөҚ = вҢҠ c вҢӢЛў вҶҰ вҢҠ d вҢӢЛў

mutual
  wtS : вҲҖ {A B} (s : A вҮЁвҒҝ B)
    вҶ’ вҠў вҢҠ s вҢӢЛў вҰӮ A вҮЁ B
  wtI : вҲҖ {A B} (i : A вҮЁвҒұ B)
    вҶ’ вҠў вҢҠ i вҢӢвҒұ вҰӮ A вҮЁ B
  wtG : вҲҖ {A B} (g : A вҮЁбөҚ B)
    вҶ’ вҠў вҢҠ g вҢӢбөҚ вҰӮ A вҮЁ B

  wtS (idвҒҝ A) = вҠўidб¶ң
  wtS (G ?вҒҝ g) = вҠў? g
  wtS (G ?вҒҝ g вЁҫ i) = вҠўвЁҹ (вҠў? g) (wtI i)
  wtS (G ?вҒҝ g вЁҫ!) = вҠўвЁҹ (вҠў? g) (вҠў! g)
  wtS (G ?вҒҝ g вЁҫ h вЁҫ!) = вҠўвЁҹ (вҠўвЁҹ (вҠў? g) (wtG h)) (вҠў! g)
  wtS (вҖІ i) = wtI i

  wtI (G !вҒҝ g) = вҠў! g
  wtI (вҖ№ G вҖә g вЁҫ gnd !вҒҝ) = вҠўвЁҹ (wtG g) (вҠў! gnd)
  wtI (пјҮ g) = wtG g
  wtI (вҠҘвҒҝ A вҮЁ B) = вҠўвҠҘ

  wtG (c вҶЈ d) = вҠўвҶҰ (wtS c) (wtS d)

mutual
  normalize-seq : вҲҖ {A B C}
    вҶ’ (s : A вҮЁвҒҝ B)
    вҶ’ (t : B вҮЁвҒҝ C)
    вҶ’ ОЈ[ u вҲҲ A вҮЁвҒҝ C ] ((вҢҠ s вҢӢЛў вЁҹ вҢҠ t вҢӢЛў) вҖ”вҶ б¶ңб¶ң вҢҠ u вҢӢЛў)

  _iвЁҹs_ : вҲҖ {A B C}
    вҶ’ (i : A вҮЁвҒұ B)
    вҶ’ (t : B вҮЁвҒҝ C)
    вҶ’ (ОЈ[ j вҲҲ A вҮЁвҒұ C ] ((вҢҠ i вҢӢвҒұ вЁҹ вҢҠ t вҢӢЛў) вҖ”вҶ б¶ңб¶ң вҢҠ j вҢӢвҒұ))
      вҠҺ (A вүЎ C Г— ((вҢҠ i вҢӢвҒұ вЁҹ вҢҠ t вҢӢЛў) вҖ”вҶ б¶ңб¶ң idб¶ң A))

  _gвЁҹi_ : вҲҖ {A B C}
    вҶ’ (g : A вҮЁбөҚ B)
    вҶ’ (i : B вҮЁвҒұ C)
    вҶ’ ОЈ[ j вҲҲ A вҮЁвҒұ C ] ((вҢҠ g вҢӢбөҚ вЁҹ вҢҠ i вҢӢвҒұ) вҖ”вҶ б¶ңб¶ң вҢҠ j вҢӢвҒұ)

  _gвЁҹg_ : вҲҖ {A B C}
    вҶ’ (g : A вҮЁбөҚ B)
    вҶ’ (h : B вҮЁбөҚ C)
    вҶ’ ОЈ[ k вҲҲ A вҮЁбөҚ C ] ((вҢҠ g вҢӢбөҚ вЁҹ вҢҠ h вҢӢбөҚ) вҖ”вҶ б¶ңб¶ң вҢҠ k вҢӢбөҚ)

  normalize-seq (idвҒҝ A) t =
    t
    , (((idб¶ң A) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idLб¶ң вҹ©
      вҢҠ t вҢӢЛў
      вҲҺб¶ңб¶ң)

  normalize-seq (G ?вҒҝ g) (idвҒҝ G) =
    G ?вҒҝ g
    , (((G `?) вЁҹ idб¶ң G
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idRб¶ң вҹ©
      (G `?)
      вҲҺб¶ңб¶ң))

  normalize-seq (G ?вҒҝ g) (вҖІ i) =
    G ?вҒҝ g вЁҫ i
    , (((G `?) вЁҹ вҢҠ i вҢӢвҒұ) вҲҺб¶ңб¶ң)

  normalize-seq (G ?вҒҝ g вЁҫ i) t
    with i iвЁҹs t
  ... | injвӮҒ (j , iвЁҹtвҶ j) =
    G ?вҒҝ g вЁҫ j
    , ((((G `?) вЁҹ вҢҠ i вҢӢвҒұ) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocRб¶ң вҹ©
      ((G `?) вЁҹ (вҢҠ i вҢӢвҒұ вЁҹ вҢҠ t вҢӢЛў))
      вҖ”вҶ б¶ңб¶ңвҹЁ multi-Оҫ-вЁҹвӮӮб¶ңб¶ң iвЁҹtвҶ j вҹ©
      ((G `?) вЁҹ вҢҠ j вҢӢвҒұ)
      вҲҺб¶ңб¶ң)
  ... | injвӮӮ (refl , iвЁҹtвҶ id) =
    G ?вҒҝ g
    , ((((G `?) вЁҹ вҢҠ i вҢӢвҒұ) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocRб¶ң вҹ©
      ((G `?) вЁҹ (вҢҠ i вҢӢвҒұ вЁҹ вҢҠ t вҢӢЛў))
      вҖ”вҶ б¶ңб¶ңвҹЁ multi-Оҫ-вЁҹвӮӮб¶ңб¶ң iвЁҹtвҶ id вҹ©
      ((G `?) вЁҹ idб¶ң G)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idRб¶ң вҹ©
      (G `?)
      вҲҺб¶ңб¶ң)

  normalize-seq (G ?вҒҝ g вЁҫ h вЁҫ!) t
    with (вҖ№ G вҖә h вЁҫ g !вҒҝ) iвЁҹs t
  ... | injвӮҒ (j , h!вЁҹtвҶ j) =
    G ?вҒҝ g вЁҫ j
    , (((((G `?) вЁҹ вҢҠ h вҢӢбөҚ) вЁҹ (G !)) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ’б¶ңб¶ңвҹЁ Оҫ-вЁҹвӮҒб¶ң ОІ-assocRб¶ң вҹ©
      ((G `?) вЁҹ (вҢҠ h вҢӢбөҚ вЁҹ (G !))) вЁҹ вҢҠ t вҢӢЛў
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocRб¶ң вҹ©
      (G `?) вЁҹ ((вҢҠ h вҢӢбөҚ вЁҹ (G !)) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ б¶ңб¶ңвҹЁ multi-Оҫ-вЁҹвӮӮб¶ңб¶ң h!вЁҹtвҶ j вҹ©
      (G `?) вЁҹ вҢҠ j вҢӢвҒұ
      вҲҺб¶ңб¶ң)
  ... | injвӮӮ (refl , h!вЁҹtвҶ id) =
    G ?вҒҝ g
    , (((((G `?) вЁҹ вҢҠ h вҢӢбөҚ) вЁҹ (G !)) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ’б¶ңб¶ңвҹЁ Оҫ-вЁҹвӮҒб¶ң ОІ-assocRб¶ң вҹ©
      ((G `?) вЁҹ (вҢҠ h вҢӢбөҚ вЁҹ (G !))) вЁҹ вҢҠ t вҢӢЛў
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocRб¶ң вҹ©
      (G `?) вЁҹ ((вҢҠ h вҢӢбөҚ вЁҹ (G !)) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ б¶ңб¶ңвҹЁ multi-Оҫ-вЁҹвӮӮб¶ңб¶ң h!вЁҹtвҶ id вҹ©
      ((G `?) вЁҹ idб¶ң G)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idRб¶ң вҹ©
      (G `?)
      вҲҺб¶ңб¶ң)

  normalize-seq (G ?вҒҝ g вЁҫ!) t
    with (G !вҒҝ g) iвЁҹs t
  ... | injвӮҒ (j , !вЁҹtвҶ j) =
    G ?вҒҝ g вЁҫ j
    , ((((G `?) вЁҹ (G !)) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocRб¶ң вҹ©
      ((G `?) вЁҹ ((G !) вЁҹ вҢҠ t вҢӢЛў))
      вҖ”вҶ б¶ңб¶ңвҹЁ multi-Оҫ-вЁҹвӮӮб¶ңб¶ң !вЁҹtвҶ j вҹ©
      ((G `?) вЁҹ вҢҠ j вҢӢвҒұ)
      вҲҺб¶ңб¶ң)
  ... | injвӮӮ (refl , !вЁҹtвҶ id) =
    G ?вҒҝ g
    , ((((G `?) вЁҹ (G !)) вЁҹ вҢҠ t вҢӢЛў)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocRб¶ң вҹ©
      ((G `?) вЁҹ ((G !) вЁҹ вҢҠ t вҢӢЛў))
      вҖ”вҶ б¶ңб¶ңвҹЁ multi-Оҫ-вЁҹвӮӮб¶ңб¶ң !вЁҹtвҶ id вҹ©
      ((G `?) вЁҹ idб¶ң G)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idRб¶ң вҹ©
      (G `?)
      вҲҺб¶ңб¶ң)

  normalize-seq (вҖІ i) t
    with i iвЁҹs t
  ... | injвӮҒ (j , iвЁҹtвҶ j) =
    вҖІ j , iвЁҹtвҶ j
  ... | injвӮӮ (refl , iвЁҹtвҶ id) =
    idвҒҝ _ , iвЁҹtвҶ id

  _iвЁҹs_ (G !вҒҝ g) (idвҒҝ вҳ…) =
    injвӮҒ (G !вҒҝ g
    , (((G !) вЁҹ (idб¶ң вҳ…)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idRб¶ң вҹ©
      (G !)
      вҲҺб¶ңб¶ң)))

  _iвЁҹs_ (в„• !вҒҝ G-в„•) (в„• ?вҒҝ G-в„•) =
    injвӮӮ (refl
    , (((в„• !) вЁҹ (в„• `?)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-proj-inj-okб¶ң вҹ©
      idб¶ң в„•
      вҲҺб¶ңб¶ң)))

  _iвЁҹs_ ((вҳ… вҮ’ вҳ…) !вҒҝ G-вҮ’) ((вҳ… вҮ’ вҳ…) ?вҒҝ G-вҮ’) =
    injвӮӮ (refl
    , ((((вҳ… вҮ’ вҳ…) !) вЁҹ ((вҳ… вҮ’ вҳ…) `?)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-proj-inj-okб¶ң вҹ©
      idб¶ң (вҳ… вҮ’ вҳ…)
      вҲҺб¶ңб¶ң)))

  _iвЁҹs_ {C = C} (в„• !вҒҝ G-в„•) ((вҳ… вҮ’ вҳ…) ?вҒҝ G-вҮ’) =
    injвӮҒ (вҠҘвҒҝ в„• вҮЁ C
    , (((в„• !) вЁҹ ((вҳ… вҮ’ вҳ…) `?)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-proj-inj-badб¶ң (О» ()) вҹ©
      (вҠҘб¶ң в„• вҮЁ (вҳ… вҮ’ вҳ…))
      вҲҺб¶ңб¶ң)))

  _iвЁҹs_ {C = C} ((вҳ… вҮ’ вҳ…) !вҒҝ G-вҮ’) (в„• ?вҒҝ G-в„•) =
    injвӮҒ (вҠҘвҒҝ (вҳ… вҮ’ вҳ…) вҮЁ C
    , ((((вҳ… вҮ’ вҳ…) !) вЁҹ (в„• `?)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-proj-inj-badб¶ң (О» ()) вҹ©
      (вҠҘб¶ң (вҳ… вҮ’ вҳ…) вҮЁ в„•)
      вҲҺб¶ңб¶ң)))

  _iвЁҹs_ (в„• !вҒҝ G-в„•) (в„• ?вҒҝ G-в„• вЁҫ i) =
    injвӮҒ (i
    , (((в„• !) вЁҹ (((в„• `?)) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocLб¶ң вҹ©
      (((в„• !) вЁҹ (в„• `?)) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ Оҫ-вЁҹвӮҒб¶ң ОІ-proj-inj-okб¶ң вҹ©
      ((idб¶ң в„•) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idLб¶ң вҹ©
      вҢҠ i вҢӢвҒұ
      вҲҺб¶ңб¶ң)))

  _iвЁҹs_ ((вҳ… вҮ’ вҳ…) !вҒҝ G-вҮ’) ((вҳ… вҮ’ вҳ…) ?вҒҝ G-вҮ’ вЁҫ i) =
    injвӮҒ (i
    , ((((вҳ… вҮ’ вҳ…) !) вЁҹ (((вҳ… вҮ’ вҳ…) `?) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocLб¶ң вҹ©
      ((((вҳ… вҮ’ вҳ…) !) вЁҹ ((вҳ… вҮ’ вҳ…) `?)) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ Оҫ-вЁҹвӮҒб¶ң ОІ-proj-inj-okб¶ң вҹ©
      ((idб¶ң (вҳ… вҮ’ вҳ…)) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-idLб¶ң вҹ©
      вҢҠ i вҢӢвҒұ
      вҲҺб¶ңб¶ң)))

  _iвЁҹs_ {C = C} (в„• !вҒҝ G-в„•) ((вҳ… вҮ’ вҳ…) ?вҒҝ G-вҮ’ вЁҫ i) =
    injвӮҒ (вҠҘвҒҝ в„• вҮЁ C
    , (((в„• !) вЁҹ (((вҳ… вҮ’ вҳ…) `?) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-assocLб¶ң вҹ©
      (((в„• !) вЁҹ ((вҳ… вҮ’ вҳ…) `?)) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ Оҫ-вЁҹвӮҒб¶ң (ОІ-proj-inj-badб¶ң (О» ())) вҹ©
      ((вҠҘб¶ң в„• вҮЁ (вҳ… вҮ’ вҳ…)) вЁҹ вҢҠ i вҢӢвҒұ)
      вҖ”вҶ’б¶ңб¶ңвҹЁ ОІ-вҠҘLб¶ң (wtI i) вҹ©
