    ‹ G › k ⨾ gnd !ⁿ
    , ((⌊ g ⌋ᵍ ⨟ (⌊ h ⌋ᵍ ⨟ (G !)))
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      (((⌊ g ⌋ᵍ) ⨟ ⌊ h ⌋ᵍ) ⨟ (G !))
      —↠ᶜᶜ⟨ multi-ξ-⨟₁ᶜᶜ g⨟g↠k ⟩
      (⌊ k ⌋ᵍ ⨟ (G !))
      ∎ᶜᶜ)

  _g⨟i_ {C = C} idℕ (⊥ⁿ ℕ ⇨ C) =
    ⊥ⁿ ℕ ⇨ C
    , (((idᶜ ℕ) ⨟ (⊥ᶜ ℕ ⇨ C))
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      (⊥ᶜ ℕ ⇨ C)
      ∎ᶜᶜ)

  _g⨟i_ {C = C} id★⇒★ (⊥ⁿ (★ ⇒ ★) ⇨ C) =
    ⊥ⁿ (★ ⇒ ★) ⇨ C
    , (((idᶜ (★ ⇒ ★)) ⨟ (⊥ᶜ (★ ⇒ ★) ⇨ C))
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      (⊥ᶜ (★ ⇒ ★) ⇨ C)
      ∎ᶜᶜ)

  _g⨟i_ {A = A₁ ⇒ B₁} {B = C₁ ⇒ D₁} {C = E} (c ↣ d) (⊥ⁿ (C₁ ⇒ D₁) ⇨ E) =
    ⊥ⁿ (A₁ ⇒ B₁) ⇨ E
    , (((⌊ c ⌋ˢ ↦ ⌊ d ⌋ˢ) ⨟ (⊥ᶜ (C₁ ⇒ D₁) ⇨ E))
      —→ᶜᶜ⟨ β-↦⊥ᶜ (wtS c) (wtS d) ⟩
      (⊥ᶜ (A₁ ⇒ B₁) ⇨ E)
      ∎ᶜᶜ)

  _g⨟i_ g (＇ h)
    with g g⨟g h
  ... | k , g⨟g↠k =
    ＇ k , g⨟g↠k

  _g⨟g_ idℕ idℕ =
    idℕ
    , (((idᶜ ℕ) ⨟ (idᶜ ℕ))
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      (idᶜ ℕ)
      ∎ᶜᶜ)

  _g⨟g_ id★⇒★ id★⇒★ =
    id★⇒★
    , (((idᶜ (★ ⇒ ★)) ⨟ (idᶜ (★ ⇒ ★)))
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      (idᶜ (★ ⇒ ★))
      ∎ᶜᶜ)

  _g⨟g_ {A = ★ ⇒ ★} {B = ★ ⇒ ★} id★⇒★ (c ↣ d) =
    (c ↣ d)
    , (((idᶜ (★ ⇒ ★)) ⨟ (⌊ c ⌋ˢ ↦ ⌊ d ⌋ˢ))
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      (⌊ c ⌋ˢ ↦ ⌊ d ⌋ˢ)
      ∎ᶜᶜ)

  _g⨟g_ {B = ★ ⇒ ★} {C = ★ ⇒ ★} (c ↣ d) id★⇒★ =
    (c ↣ d)
    , (((⌊ c ⌋ˢ ↦ ⌊ d ⌋ˢ) ⨟ (idᶜ (★ ⇒ ★)))
      —→ᶜᶜ⟨ β-idRᶜ ⟩
      (⌊ c ⌋ˢ ↦ ⌊ d ⌋ˢ)
      ∎ᶜᶜ)

  _g⨟g_ (c ↣ d) (c′ ↣ d′)
    with normalize-seq c′ c
  ... | lc , c′⨟c↠lc
    with normalize-seq d d′
  ... | rd , d⨟d′↠rd =
    (lc ↣ rd)
    , (((⌊ c ⌋ˢ ↦ ⌊ d ⌋ˢ) ⨟ (⌊ c′ ⌋ˢ ↦ ⌊ d′ ⌋ˢ))
      —→ᶜᶜ⟨ β-↦ᶜ ⟩
      ((⌊ c′ ⌋ˢ ⨟ ⌊ c ⌋ˢ) ↦ (⌊ d ⌋ˢ ⨟ ⌊ d′ ⌋ˢ))
      —↠ᶜᶜ⟨ multi-ξ-↦₁ᶜᶜ c′⨟c↠lc ⟩
      (⌊ lc ⌋ˢ ↦ (⌊ d ⌋ˢ ⨟ ⌊ d′ ⌋ˢ))
      —↠ᶜᶜ⟨ multi-ξ-↦₂ᶜᶜ d⨟d′↠rd ⟩
      (⌊ lc ⌋ˢ ↦ ⌊ rd ⌋ˢ)
      ∎ᶜᶜ)

ground-idⁿ : ∀ {G} → Ground G → G ⇨ᵍ G
ground-idⁿ G-ℕ = idℕ
ground-idⁿ G-⇒ = id★⇒★

inverse-erase
  : ∀ {c A B}
  → ⊢ c ⦂ A ⇨ B
  → Normalᶜ c
  → ∃[ s ] (⌊ s ⌋ˢ ≡ c)

inverse-erase {c = idᶜ A} ⊢idᶜ nf-id =
  idⁿ A , refl

inverse-erase {c = ℕ `?} (⊢? G-ℕ) (nf-? G-ℕ) =
  ℕ ?ⁿ G-ℕ , refl

inverse-erase {c = (★ ⇒ ★) `?} (⊢? G-⇒) (nf-? G-⇒) =
  (★ ⇒ ★) ?ⁿ G-⇒ , refl

inverse-erase {c = ℕ !} (⊢! G-ℕ) (nf-! G-ℕ) =
  ′ (ℕ !ⁿ G-ℕ) , refl

inverse-erase {c = (★ ⇒ ★) !} (⊢! G-⇒) (nf-! G-⇒) =
  ′ ((★ ⇒ ★) !ⁿ G-⇒) , refl

inverse-erase {c = (ℕ `?) ⨟ (ℕ !)}
  (⊢⨟ (⊢? G-ℕ) (⊢! G-ℕ)) (nf-?! G-ℕ) =
  ℕ ?ⁿ G-ℕ ⨾ (ℕ !ⁿ G-ℕ) , refl

inverse-erase {c = ((★ ⇒ ★) `?) ⨟ ((★ ⇒ ★) !)}
  (⊢⨟ (⊢? G-⇒) (⊢! G-⇒)) (nf-?! G-⇒) =
  (★ ⇒ ★) ?ⁿ G-⇒ ⨾ ((★ ⇒ ★) !ⁿ G-⇒) , refl

inverse-erase {c = c₁ ↦ c₂}
  (⊢↦ cwt dwt) (nf-↦ n₁ n₂)
  with inverse-erase cwt n₁ | inverse-erase dwt n₂
... | s₁ , eq₁ | s₂ , eq₂ =
  ′ (＇ (s₁ ↣ s₂)) , cong₂ _↦_ eq₁ eq₂

inverse-erase {c = (G `?) ⨟ (c₁ ↦ c₂)}
  (⊢⨟ (⊢? g) (⊢↦ cwt dwt)) (nf-?↦ _ n₁ n₂)
  with inverse-erase cwt n₁ | inverse-erase dwt n₂
... | s₁ , eq₁ | s₂ , eq₂ =
  G ?ⁿ g ⨾ (＇ (s₁ ↣ s₂))
  , cong (λ x → (G `?) ⨟ x) (cong₂ _↦_ eq₁ eq₂)

inverse-erase {c = (c₁ ↦ c₂) ⨟ ((★ ⇒ ★) !)}
  (⊢⨟ (⊢↦ cwt dwt) (⊢! G-⇒)) (nf-↦! n₁ n₂ G-⇒)
  with inverse-erase cwt n₁ | inverse-erase dwt n₂
... | s₁ , eq₁ | s₂ , eq₂ =
  ′ (‹ (★ ⇒ ★) › (s₁ ↣ s₂) ⨾ G-⇒ !ⁿ)
  , cong (λ x → x ⨟ ((★ ⇒ ★) !)) (cong₂ _↦_ eq₁ eq₂)

inverse-erase {c = ((★ ⇒ ★) `? ⨟ (c₁ ↦ c₂)) ⨟ ((★ ⇒ ★) !)}
  (⊢⨟ (⊢⨟ (⊢? G-⇒) (⊢↦ cwt dwt)) (⊢! G-⇒))
  (nf-?↦! G-⇒ n₁ n₂)
  with inverse-erase cwt n₁ | inverse-erase dwt n₂
... | s₁ , eq₁ | s₂ , eq₂ =
  (★ ⇒ ★) ?ⁿ G-⇒ ⨾ (s₁ ↣ s₂) ⨾!
  , cong (λ x → ((★ ⇒ ★) `? ⨟ x) ⨟ ((★ ⇒ ★) !)) (cong₂ _↦_ eq₁ eq₂)

inverse-erase {c = (G `?) ⨟ (⊥ᶜ A ⇨ B)}
  (⊢⨟ (⊢? g) ⊢⊥) (nf-?⊥ _) =
  G ?ⁿ g ⨾ (⊥ⁿ G ⇨ B) , refl

inverse-erase {c = ⊥ᶜ A ⇨ B} ⊢⊥ nf-⊥ =
  ′ (⊥ⁿ A ⇨ B) , refl

erase-normal
  : ∀ {A B}
  → (s : A ⇨ⁿ B)
  → ∃[ c ] (⌊ s ⌋ˢ —↠ᶜᶜ c) × Normalᶜ c
erase-normal s = normalizeᶜ (wtS s)

erase-produces-Normalᶜ
  : ∀ {A B}
  → (s : A ⇨ⁿ B)
  → ∃[ c ] (⌊ s ⌋ˢ —↠ᶜᶜ c) × Normalᶜ c
erase-produces-Normalᶜ = erase-normal
