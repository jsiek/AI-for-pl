open import Data.Nat using (в„•; _<_; zero; suc; z<s; s<s)
open import Data.Nat.Properties using (_вүҹ_)
open import Data.Product using (_Г—_; _,_; projвӮҒ; projвӮӮ; вҲғ; вҲғ-syntax)
