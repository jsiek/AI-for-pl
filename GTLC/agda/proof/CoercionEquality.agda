module proof.CoercionEquality where

open import Agda.Builtin.List using ([])
open import Data.Product using (ОЈ-syntax; вҲғ-syntax; _Г—_; _,_)
open import Relation.Binary.PropositionalEquality using (_вүў_; refl)

open import Types
open import proof.CoercionReduction

infix 4 _вүҲб¶ң_

data _вүҲб¶ң_ : Coercion вҶ’ Coercion вҶ’ Set where
  вүҲ-refl : вҲҖ {c}
    вҶ’ c вүҲб¶ң c

  вүҲ-sym : вҲҖ {c d}
    вҶ’ c вүҲб¶ң d
    вҶ’ d вүҲб¶ң c

  вүҲ-trans : вҲҖ {c d e}
    вҶ’ c вүҲб¶ң d
    вҶ’ d вүҲб¶ң e
    вҶ’ c вүҲб¶ң e

  вүҲ-вҶҰ : вҲҖ {cвӮҒ cвӮӮ dвӮҒ dвӮӮ}
    вҶ’ cвӮҒ вүҲб¶ң cвӮӮ
    вҶ’ dвӮҒ вүҲб¶ң dвӮӮ
    вҶ’ singleб¶ң (cвӮҒ вҶҰ dвӮҒ) вүҲб¶ң singleб¶ң (cвӮӮ вҶҰ dвӮӮ)

  вүҲ-вЁҹ : вҲҖ {cвӮҒ cвӮӮ dвӮҒ dвӮӮ}
    вҶ’ cвӮҒ вүҲб¶ң cвӮӮ
    вҶ’ dвӮҒ вүҲб¶ң dвӮӮ
    вҶ’ (cвӮҒ вЁҹ dвӮҒ) вүҲб¶ң (cвӮӮ вЁҹ dвӮӮ)

  -- Rules mirroring one-step reduction rules.
  вүҲ-ОІ-proj-inj-ok : вҲҖ {G в„“}
    вҶ’ singleб¶ң (G !) вЁҹ singleб¶ң (G пјҹ в„“) вүҲб¶ң []

  вүҲ-ОІ-proj-inj-bad : вҲҖ {G H в„“}
    вҶ’ G вүў H
    вҶ’ singleб¶ң (G !) вЁҹ singleб¶ң (H пјҹ в„“)
      вүҲб¶ң singleб¶ң (вҠҘб¶ң G вҮЁ H at в„“)

  вүҲ-ОІ-idL : вҲҖ {d}
    вҶ’ [] вЁҹ d вүҲб¶ң d

  вүҲ-ОІ-idR : вҲҖ {c}
    вҶ’ c вЁҹ [] вүҲб¶ң c

  вүҲ-ОІ-assocL : вҲҖ {cвӮҒ cвӮӮ cвӮғ}
    вҶ’ (cвӮҒ вЁҹ (cвӮӮ вЁҹ cвӮғ)) вүҲб¶ң ((cвӮҒ вЁҹ cвӮӮ) вЁҹ cвӮғ)

  вүҲ-ОІ-assocR : вҲҖ {cвӮҒ cвӮӮ cвӮғ}
    вҶ’ ((cвӮҒ вЁҹ cвӮӮ) вЁҹ cвӮғ) вүҲб¶ң (cвӮҒ вЁҹ (cвӮӮ вЁҹ cвӮғ))

  вүҲ-ОІ-вҶҰ : вҲҖ {c d cвҖІ dвҖІ}
    вҶ’ singleб¶ң (c вҶҰ d) вЁҹ singleб¶ң (cвҖІ вҶҰ dвҖІ)
      вүҲб¶ң singleб¶ң ((cвҖІ вЁҹ c) вҶҰ (d вЁҹ dвҖІ))

  вүҲ-ОІ-вҠҘL : вҲҖ {A B C d в„“}
    вҶ’ вҠў d вҰӮ B вҮЁб¶ң C
    вҶ’ singleб¶ң (вҠҘб¶ң A вҮЁ B at в„“) вЁҹ singleб¶ң d
      вүҲб¶ң singleб¶ң (вҠҘб¶ң A вҮЁ C at в„“)

  вүҲ-ОІ-!вҠҘ : вҲҖ {G B в„“}
    вҶ’ singleб¶ң (G !) вЁҹ singleб¶ң (вҠҘб¶ң вҳ… вҮЁ B at в„“)
      вүҲб¶ң singleб¶ң (вҠҘб¶ң G вҮЁ B at в„“)

  вүҲ-ОІ-вҶҰвҠҘ : вҲҖ {c d A B C D E в„“}
    вҶ’ вҠў c вҰӮ C вҮЁ A
    вҶ’ вҠў d вҰӮ B вҮЁ D
    вҶ’ singleб¶ң (c вҶҰ d) вЁҹ singleб¶ң (вҠҘб¶ң (C вҮ’ D) вҮЁ E at в„“)
      вүҲб¶ң singleб¶ң (вҠҘб¶ң (A вҮ’ B) вҮЁ E at в„“)

вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң : вҲҖ {c d}
  вҶ’ c вҖ”вҶ’б¶ңб¶ң d
  вҶ’ c вүҲб¶ң d
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-pair ОІ-proj-inj-okб¶ң refl) =
  вүҲ-вЁҹ вүҲ-ОІ-proj-inj-ok вүҲ-refl
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-pair (ОІ-proj-inj-badб¶ң GвүўH) refl) =
  вүҲ-вЁҹ (вүҲ-ОІ-proj-inj-bad GвүўH) вүҲ-refl
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-pair ОІ-вҶҰб¶ң refl) =
  вүҲ-вЁҹ вүҲ-ОІ-вҶҰ вүҲ-refl
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-pair (ОІ-вҠҘLб¶ң dwt) refl) =
  вүҲ-вЁҹ (вүҲ-ОІ-вҠҘL dwt) вүҲ-refl
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-pair ОІ-!вҠҘб¶ң refl) =
  вүҲ-вЁҹ вүҲ-ОІ-!вҠҘ вүҲ-refl
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-pair (ОІ-вҶҰвҠҘб¶ң cwt dwt) refl) =
  вүҲ-вЁҹ (вүҲ-ОІ-вҶҰвҠҘ cwt dwt) вүҲ-refl
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-вҲ·б¶ң {c = c} cвҶ’cвҖІ) =
  вүҲ-вЁҹ {cвӮҒ = singleб¶ң c} вүҲ-refl (вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң cвҶ’cвҖІ)
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-вҶҰвӮҒб¶ң {d = d} {cs = cs} cвҶ’cвҖІ) =
  вүҲ-вЁҹ {dвӮҒ = cs} (вүҲ-вҶҰ (вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң cвҶ’cвҖІ) вүҲ-refl) вүҲ-refl
вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң (Оҫ-вҶҰвӮӮб¶ң {c = c} {cs = cs} dвҶ’dвҖІ) =
  вүҲ-вЁҹ {dвӮҒ = cs} (вүҲ-вҶҰ вүҲ-refl (вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң dвҶ’dвҖІ)) вүҲ-refl

вҖ”вҶ б¶ңб¶ңвҮ’вүҲб¶ң : вҲҖ {c d}
  вҶ’ c вҖ”вҶ б¶ңб¶ң d
  вҶ’ c вүҲб¶ң d
вҖ”вҶ б¶ңб¶ңвҮ’вүҲб¶ң (_ вҲҺб¶ңб¶ң) = вүҲ-refl
вҖ”вҶ б¶ңб¶ңвҮ’вүҲб¶ң (_ вҖ”вҶ’б¶ңб¶ңвҹЁ cвҶ’cвӮҒ вҹ© cвӮҒвҶ d) =
  вүҲ-trans (вҖ”вҶ’б¶ңб¶ңвҮ’вүҲб¶ң cвҶ’cвӮҒ) (вҖ”вҶ б¶ңб¶ңвҮ’вүҲб¶ң cвӮҒвҶ d)

вүҲб¶ң-complete : вҲҖ {c d cвҖІ}
  вҶ’ c вҖ”вҶ б¶ңб¶ң cвҖІ
  вҶ’ d вҖ”вҶ б¶ңб¶ң cвҖІ
  вҶ’ c вүҲб¶ң d
вүҲб¶ң-complete cвҶ cвҖІ dвҶ cвҖІ =
  вүҲ-trans (вҖ”вҶ б¶ңб¶ңвҮ’вүҲб¶ң cвҶ cвҖІ) (вүҲ-sym (вҖ”вҶ б¶ңб¶ңвҮ’вүҲб¶ң dвҶ cвҖІ))
