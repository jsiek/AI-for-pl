{-
  Term imprecision for the Nu syntax.

  This file mechanizes the term-imprecision relation from
  cambridge22.lagda.md.  The paper presentation uses a combined environment
  for term variables and seal assumptions; here we split it into the store
  widening context from NarrowWiden and a term-variable context of coercions.

  Freshness side conditions from the paper are not reified here.  The paper's
  +/- cast notation is represented using NuTerms' single raw cast form and the
  coercion dual operator `-_`, with the corresponding coercion-equivalence
  premise made explicit.
-}

module TermNarrowing where

open import Data.List using (_вҲ·_; map)
open import Data.Nat using (zero; suc)

open import Types
open import Coercions
open import Primitives
open import NuTerms
open import NarrowWiden

variable
  О” : TyCtx
  ОЈ : Store
  Пғ : StoreWid
  Оі : CtxWid
  A AвҖІ B : Ty
  p q r s t : Coercion
  M MвҖІ N NвҖІ L LвҖІ V VвҖІ : Term
  x : Var
  Оұ Оұбөў : TyVar

вҮ‘бөҚ : CtxWid вҶ’ CtxWid
вҮ‘бөҚ = map вҮ‘б¶ң

infix 4 _вҲЈ_вҲЈ_вҠў_вҠ’_вҲ¶_

data _вҲЈ_вҲЈ_вҠў_вҠ’_вҲ¶_
    : TyCtx вҶ’ StoreWid вҶ’ CtxWid вҶ’ Term вҶ’ Term вҶ’ Coercion вҶ’ SetвӮҒ where

  extend : вҲҖ {M NвҖІ p q A B Оұ ОЈ}
    вҶ’ О” вҲЈ ОЈ вҠў q вҲ¶ B вҠ’ A
    вҶ’ О” вҲЈ (Оұ кһү= A вҠ‘) вҲ· Пғ вҲЈ Оі
        вҠў M вҠ’ NвҖІ [ Оұ ]бөҖ вҲ¶ p [ Оұ ]б¶ң
      ------------------------------------------------------
    вҶ’ О” вҲЈ (Оұ кһү q) вҲ· Пғ вҲЈ Оі вҠў M вҠ’ NвҖІ [ Оұ ]бөҖ вҲ¶ p [ Оұ ]б¶ң

  split : вҲҖ {N NвҖІ p q A Оұ Оұбөў ОЈ}
    вҶ’ О” вҲЈ ОЈ вҠў q вҲ¶ вҳ… вҠ’ A
    вҶ’ О” вҲЈ (Оұ кһү q) вҲ· Пғ вҲЈ Оі
        вҠў N [ Оұ ]бөҖ вҠ’ NвҖІ [ Оұ ]бөҖ вҲ¶ p [ Оұ ]б¶ң
      ----------------------------------------------------------
    вҶ’ О” вҲЈ (Оұ кһү= A вҠ‘) вҲ· (вҠ‘ Оұбөў кһү=вҳҶ) вҲ· Пғ вҲЈ Оі
        вҠў N [ Оұбөў ]бөҖ вҠ’ NвҖІ [ Оұ ]бөҖ вҲ¶ p [ Оұ ]б¶ң

  вҠ’blame : вҲҖ {M p}
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ blame вҲ¶ p

  xвҠ’x : вҲҖ {x p}
    вҶ’ Оі вҲӢ x вҰӮ p
      -------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў ` x вҠ’ ` x вҲ¶ p

  ЖӣвҠ’Жӣ : вҲҖ {N NвҖІ p q}
    вҶ’ О” вҲЈ Пғ вҲЈ ((- p) вҲ· Оі) вҠў N вҠ’ NвҖІ вҲ¶ q
      ---------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў Жӣ N вҠ’ Жӣ NвҖІ вҲ¶ p вҶҰ q

  В·вҠ’В· : вҲҖ {L LвҖІ M MвҖІ p q}
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў L вҠ’ LвҖІ вҲ¶ p вҶҰ q
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҲ¶ - p
      -------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў L В· M вҠ’ LвҖІ В· MвҖІ вҲ¶ q

  ОӣвҠ’Оӣ : вҲҖ {V VвҖІ p}
    вҶ’ suc О” вҲЈ вҮ‘Лў Пғ вҲЈ вҮ‘бөҚ Оі вҠў V вҠ’ VвҖІ вҲ¶ p
      ------------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў Оӣ V вҠ’ Оӣ VвҖІ вҲ¶ `вҲҖ p

  вҠ’Оӣ : вҲҖ {N VвҖІ p}
    вҶ’ suc О” вҲЈ (zero кһү id вҳ…) вҲ· вҮ‘Лў Пғ вҲЈ вҮ‘бөҚ Оі вҠў вҮ‘бө—бөҗ N вҠ’ VвҖІ вҲ¶ p
      --------------------------------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў N вҠ’ Оӣ VвҖІ вҲ¶ gen вҳ… p

  вҠ’вҹЁОҪвҹ© : вҲҖ {N VвҖІ p s}
    вҶ’ suc О” вҲЈ (zero кһү id вҳ…) вҲ· вҮ‘Лў Пғ вҲЈ вҮ‘бөҚ Оі
        вҠў вҮ‘бө—бөҗ N вҠ’ VвҖІ вҹЁ s вҹ© вҲ¶ p
      ----------------------------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў N вҠ’ VвҖІ вҹЁ gen вҳ… s вҹ© вҲ¶ gen вҳ… p

  ОұвҠ’Оұ : вҲҖ {L LвҖІ p q Оұ}
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў L вҠ’ LвҖІ вҲ¶ `вҲҖ p
      ------------------------------------------------
    вҶ’ О” вҲЈ (Оұ кһү q) вҲ· Пғ вҲЈ Оі вҠў L вҖў Оұ вҠ’ LвҖІ вҖў Оұ вҲ¶ p [ Оұ ]б¶ң

  вҠ’Оұ : вҲҖ {L LвҖІ p A Оұ}
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў L вҠ’ LвҖІ вҲ¶ gen A p
      -----------------------------------------------
    вҶ’ О” вҲЈ (Оұ кһү= A вҠ‘) вҲ· Пғ вҲЈ Оі вҠў L вҠ’ LвҖІ вҖў Оұ вҲ¶ p [ Оұ ]б¶ң

  ОҪвҠ’ОҪ : вҲҖ {A AвҖІ N NвҖІ p}
    вҶ’ suc О” вҲЈ (zero кһү вҮ‘б¶ң p) вҲ· вҮ‘Лў Пғ вҲЈ вҮ‘бөҚ Оі вҠў N вҠ’ NвҖІ вҲ¶ вҮ‘б¶ң p
      ------------------------------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў ОҪ A N вҠ’ ОҪ AвҖІ NвҖІ вҲ¶ p

  вҠ’ОҪ : вҲҖ {A N NвҖІ p}
    вҶ’ suc О” вҲЈ (zero кһү= вҮ‘бө— A вҠ‘) вҲ· вҮ‘Лў Пғ вҲЈ вҮ‘бөҚ Оі
        вҠў вҮ‘бө—бөҗ N вҠ’ NвҖІ вҲ¶ вҮ‘б¶ң p
      ---------------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў N вҠ’ ОҪ A NвҖІ вҲ¶ p

  ОҪвҠ’ : вҲҖ {N NвҖІ p}
    вҶ’ suc О” вҲЈ (вҠ‘ zero кһү=вҳҶ) вҲ· вҮ‘Лў Пғ вҲЈ вҮ‘бөҚ Оі
        вҠў N вҠ’ вҮ‘бө—бөҗ NвҖІ вҲ¶ вҮ‘б¶ң p
      ----------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў ОҪ вҳ… N вҠ’ NвҖІ вҲ¶ p

  ОәвҠ’Оә : вҲҖ Оә
      -------------------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў $ Оә вҠ’ $ Оә вҲ¶ id (constTy Оә)

  вҠ•вҠ’вҠ• : вҲҖ {M MвҖІ N NвҖІ}
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҲ¶ id (вҖө `в„•)
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў N вҠ’ NвҖІ вҲ¶ id (вҖө `в„•)
      -----------------------------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ•[ addв„• ] N вҠ’ MвҖІ вҠ•[ addв„• ] NвҖІ вҲ¶ id (вҖө `в„•)

  вҠ’cast+ : вҲҖ {M MвҖІ q r s A B}
    вҶ’ О” вҲЈ Пғ вҠў q пё” s вүҲ r вҲ¶ A вҠ‘ B
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҲ¶ r
      ----------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҹЁ - s вҹ© вҲ¶ q

  вҠ’cast- : вҲҖ {M MвҖІ q r s A B}
    вҶ’ О” вҲЈ Пғ вҠў q пё” s вүҲ r вҲ¶ A вҠ‘ B
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҲ¶ q
      ----------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҹЁ s вҹ© вҲ¶ r

  cast+вҠ’ : вҲҖ {M MвҖІ p r t A B}
    вҶ’ О” вҲЈ Пғ вҠў r вүҲ t пё” p вҲ¶ A вҠ‘ B
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҲ¶ p
      ----------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҹЁ - t вҹ© вҠ’ MвҖІ вҲ¶ r

  cast-вҠ’ : вҲҖ {M MвҖІ p r t A B}
    вҶ’ О” вҲЈ Пғ вҠў r вүҲ t пё” p вҲ¶ A вҠ‘ B
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҠ’ MвҖІ вҲ¶ r
      ----------------------------------
    вҶ’ О” вҲЈ Пғ вҲЈ Оі вҠў M вҹЁ t вҹ© вҠ’ MвҖІ вҲ¶ p
