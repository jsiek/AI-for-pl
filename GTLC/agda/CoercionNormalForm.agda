module CoercionNormalForm where

open import Data.Product using (Σ-syntax; ∃-syntax; _×_; _,_)
open import Relation.Binary.PropositionalEquality using (_≡_; refl; cong; cong₂)

open import Types
open import CoercionReduction

infix 7 _↣_
infix 5 _i⨟s_
infix 5 _g⨟i_
infix 5 _g⨟g_
infix 4 _⇨ⁿ_ _⇨ⁱ_ _⇨ᵍ_
infix 7 _?ⁿ_ _!ⁿ_
infix 6 _?ⁿ_⨾_ _?ⁿ_⨾_⨾! ‹_›_⨾_!ⁿ

mutual
  data _⇨ⁿ_ : Ty → Ty → Set
  data _⇨ⁱ_ : Ty → Ty → Set
  data _⇨ᵍ_ : Ty → Ty → Set

  data _⇨ⁿ_ where
    idⁿ : (A : Ty)
      → A ⇨ⁿ A
    _?ⁿ_ : ∀ (G : Ty)
      → Ground G
      → ★ ⇨ⁿ G
    _?ⁿ_⨾_ : ∀ (G : Ty) {B}
      → Ground G
      → G ⇨ⁱ B
      → ★ ⇨ⁿ B
    _?ⁿ_⨾_⨾! : ∀ (G : Ty)
      → Ground G
      → G ⇨ᵍ G
      → ★ ⇨ⁿ ★
    ′_ : ∀ {A B}
      → A ⇨ⁱ B
      → A ⇨ⁿ B

  data _⇨ⁱ_ where
    _!ⁿ_ : ∀ (G : Ty)
      → Ground G
      → G ⇨ⁱ ★
    ‹_›_⨾_!ⁿ : ∀ {A} (G : Ty)
      → A ⇨ᵍ G
      → Ground G
      → A ⇨ⁱ ★
    ＇_ : ∀ {A B}
      → A ⇨ᵍ B
      → A ⇨ⁱ B
    ⊥ⁿ_⇨_ : ∀ (A B : Ty)
      → A ⇨ⁱ B

  data _⇨ᵍ_ where
    idℕ : ℕ ⇨ᵍ ℕ
    id★⇒★ : (★ ⇒ ★) ⇨ᵍ (★ ⇒ ★)
    _↣_ : ∀ {A B C D}
      → C ⇨ⁿ A
      → B ⇨ⁿ D
      → (A ⇒ B) ⇨ᵍ (C ⇒ D)

mutual
  ⌊_⌋ˢ : ∀ {A B}
    → A ⇨ⁿ B
    → Coercion
  ⌊_⌋ⁱ : ∀ {A B}
    → A ⇨ⁱ B
    → Coercion
  ⌊_⌋ᵍ : ∀ {A B}
    → A ⇨ᵍ B
    → Coercion

  ⌊ idⁿ A ⌋ˢ = idᶜ A
  ⌊ G ?ⁿ _ ⌋ˢ = G `?
  ⌊ G ?ⁿ _ ⨾ i ⌋ˢ = G `? ⨟ ⌊ i ⌋ⁱ
  ⌊ G ?ⁿ _ ⨾ g ⨾! ⌋ˢ = (G `? ⨟ ⌊ g ⌋ᵍ) ⨟ G !
  ⌊ ′ i ⌋ˢ = ⌊ i ⌋ⁱ

  ⌊ G !ⁿ _ ⌋ⁱ = G !
  ⌊ ‹ G › g ⨾ _ !ⁿ ⌋ⁱ = ⌊ g ⌋ᵍ ⨟ G !
  ⌊ ＇ g ⌋ⁱ = ⌊ g ⌋ᵍ
  ⌊ ⊥ⁿ A ⇨ B ⌋ⁱ = ⊥ᶜ A ⇨ B

  ⌊ idℕ ⌋ᵍ = idᶜ ℕ
  ⌊ id★⇒★ ⌋ᵍ = idᶜ (★ ⇒ ★)
  ⌊ c ↣ d ⌋ᵍ = ⌊ c ⌋ˢ ↦ ⌊ d ⌋ˢ

mutual
  wtS : ∀ {A B} (s : A ⇨ⁿ B)
    → ⊢ ⌊ s ⌋ˢ ⦂ A ⇨ B
  wtI : ∀ {A B} (i : A ⇨ⁱ B)
    → ⊢ ⌊ i ⌋ⁱ ⦂ A ⇨ B
  wtG : ∀ {A B} (g : A ⇨ᵍ B)
    → ⊢ ⌊ g ⌋ᵍ ⦂ A ⇨ B

  wtS (idⁿ A) = ⊢idᶜ
  wtS (G ?ⁿ g) = ⊢? g
  wtS (G ?ⁿ g ⨾ i) = ⊢⨟ (⊢? g) (wtI i)
  wtS (G ?ⁿ g ⨾ h ⨾!) = ⊢⨟ (⊢⨟ (⊢? g) (wtG h)) (⊢! g)
  wtS (′ i) = wtI i

  wtI (G !ⁿ g) = ⊢! g
  wtI (‹ G › g ⨾ gnd !ⁿ) = ⊢⨟ (wtG g) (⊢! gnd)
  wtI (＇ g) = wtG g
  wtI (⊥ⁿ A ⇨ B) = ⊢⊥

  wtG idℕ = ⊢idᶜ
  wtG id★⇒★ = ⊢idᶜ
  wtG (c ↣ d) = ⊢↦ (wtS c) (wtS d)

mutual
  normalize-seq : ∀ {A B C}
    → (s : A ⇨ⁿ B)
    → (t : B ⇨ⁿ C)
    → ∃[ u ] ((⌊ s ⌋ˢ ⨟ ⌊ t ⌋ˢ) —↠ᶜᶜ ⌊ u ⌋ˢ)

  _i⨟s_ : ∀ {A B C}
    → (i : A ⇨ⁱ B)
    → (t : B ⇨ⁿ C)
    → ∃[ j ] ((⌊ i ⌋ⁱ ⨟ ⌊ t ⌋ˢ) —↠ᶜᶜ ⌊ j ⌋ⁱ)

  _g⨟i_ : ∀ {A B C}
    → (g : A ⇨ᵍ B)
    → (i : B ⇨ⁱ C)
    → ∃[ j ] ((⌊ g ⌋ᵍ ⨟ ⌊ i ⌋ⁱ) —↠ᶜᶜ ⌊ j ⌋ⁱ)

  _g⨟g_ : ∀ {A B C}
    → (g : A ⇨ᵍ B)
    → (h : B ⇨ᵍ C)
    → ∃[ k ] ((⌊ g ⌋ᵍ ⨟ ⌊ h ⌋ᵍ) —↠ᶜᶜ ⌊ k ⌋ᵍ)

  normalize-seq (idⁿ A) t =
    t
    , (((idᶜ A) ⨟ ⌊ t ⌋ˢ)
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      ⌊ t ⌋ˢ
      ∎ᶜᶜ)

  normalize-seq (G ?ⁿ g) (idⁿ G) =
    G ?ⁿ g
    , (((G `?) ⨟ idᶜ G
      —→ᶜᶜ⟨ β-idRᶜ ⟩
      (G `?)
      ∎ᶜᶜ))

  normalize-seq (G ?ⁿ g) (′ i) =
    G ?ⁿ g ⨾ i
    , (((G `?) ⨟ ⌊ i ⌋ⁱ) ∎ᶜᶜ)

  normalize-seq (G ?ⁿ g ⨾ i) t
    with i i⨟s t
  ... | j , i⨟t↠j =
    G ?ⁿ g ⨾ j
    , ((((G `?) ⨟ ⌊ i ⌋ⁱ) ⨟ ⌊ t ⌋ˢ)
      —→ᶜᶜ⟨ β-assocRᶜ ⟩
      ((G `?) ⨟ (⌊ i ⌋ⁱ ⨟ ⌊ t ⌋ˢ))
      —↠ᶜᶜ⟨ multi-ξ-⨟₂ᶜᶜ i⨟t↠j ⟩
      ((G `?) ⨟ ⌊ j ⌋ⁱ)
      ∎ᶜᶜ)

  normalize-seq (G ?ⁿ g ⨾ h ⨾!) t
    with (‹ G › h ⨾ g !ⁿ) i⨟s t
  ... | j , h!⨟t↠j =
    G ?ⁿ g ⨾ j
    , (((((G `?) ⨟ ⌊ h ⌋ᵍ) ⨟ (G !)) ⨟ ⌊ t ⌋ˢ)
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ β-assocRᶜ ⟩
      ((G `?) ⨟ (⌊ h ⌋ᵍ ⨟ (G !))) ⨟ ⌊ t ⌋ˢ
      —→ᶜᶜ⟨ β-assocRᶜ ⟩
      (G `?) ⨟ ((⌊ h ⌋ᵍ ⨟ (G !)) ⨟ ⌊ t ⌋ˢ)
      —↠ᶜᶜ⟨ multi-ξ-⨟₂ᶜᶜ h!⨟t↠j ⟩
      (G `?) ⨟ ⌊ j ⌋ⁱ
      ∎ᶜᶜ)

  normalize-seq (′ i) t
    with i i⨟s t
  ... | j , i⨟t↠j =
    ′ j , i⨟t↠j

  _i⨟s_ (G !ⁿ g) (idⁿ ★) =
    G !ⁿ g
    , (((G !) ⨟ (idᶜ ★)
      —→ᶜᶜ⟨ β-idRᶜ ⟩
      (G !)
      ∎ᶜᶜ))

  _i⨟s_ (ℕ !ⁿ G-ℕ) (ℕ ?ⁿ G-ℕ) =
    ＇ idℕ
    , (((ℕ !) ⨟ (ℕ `?)
      —→ᶜᶜ⟨ β-proj-inj-okᶜ ⟩
      idᶜ ℕ
      ∎ᶜᶜ))

  _i⨟s_ ((★ ⇒ ★) !ⁿ G-⇒) ((★ ⇒ ★) ?ⁿ G-⇒) =
    ＇ id★⇒★
    , ((((★ ⇒ ★) !) ⨟ ((★ ⇒ ★) `?)
      —→ᶜᶜ⟨ β-proj-inj-okᶜ ⟩
      idᶜ (★ ⇒ ★)
      ∎ᶜᶜ))

  _i⨟s_ {C = C} (ℕ !ⁿ G-ℕ) ((★ ⇒ ★) ?ⁿ G-⇒) =
    ⊥ⁿ ℕ ⇨ C
    , (((ℕ !) ⨟ ((★ ⇒ ★) `?)
      —→ᶜᶜ⟨ β-proj-inj-badᶜ (λ ()) ⟩
      (⊥ᶜ ℕ ⇨ (★ ⇒ ★))
      ∎ᶜᶜ))

  _i⨟s_ {C = C} ((★ ⇒ ★) !ⁿ G-⇒) (ℕ ?ⁿ G-ℕ) =
    ⊥ⁿ (★ ⇒ ★) ⇨ C
    , ((((★ ⇒ ★) !) ⨟ (ℕ `?)
      —→ᶜᶜ⟨ β-proj-inj-badᶜ (λ ()) ⟩
      (⊥ᶜ (★ ⇒ ★) ⇨ ℕ)
      ∎ᶜᶜ))

  _i⨟s_ (ℕ !ⁿ G-ℕ) (ℕ ?ⁿ G-ℕ ⨾ i) =
    i
    , (((ℕ !) ⨟ (((ℕ `?)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      (((ℕ !) ⨟ (ℕ `?)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ β-proj-inj-okᶜ ⟩
      ((idᶜ ℕ) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      ⌊ i ⌋ⁱ
      ∎ᶜᶜ))

  _i⨟s_ ((★ ⇒ ★) !ⁿ G-⇒) ((★ ⇒ ★) ?ⁿ G-⇒ ⨾ i) =
    i
    , ((((★ ⇒ ★) !) ⨟ (((★ ⇒ ★) `?) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      ((((★ ⇒ ★) !) ⨟ ((★ ⇒ ★) `?)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ β-proj-inj-okᶜ ⟩
      ((idᶜ (★ ⇒ ★)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      ⌊ i ⌋ⁱ
      ∎ᶜᶜ))

  _i⨟s_ {C = C} (ℕ !ⁿ G-ℕ) ((★ ⇒ ★) ?ⁿ G-⇒ ⨾ i) =
    ⊥ⁿ ℕ ⇨ C
    , (((ℕ !) ⨟ (((★ ⇒ ★) `?) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      (((ℕ !) ⨟ ((★ ⇒ ★) `?)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (β-proj-inj-badᶜ (λ ())) ⟩
      ((⊥ᶜ ℕ ⇨ (★ ⇒ ★)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-⊥Lᶜ (wtI i) ⟩
      (⊥ᶜ ℕ ⇨ C)
      ∎ᶜᶜ))

  _i⨟s_ {C = C} ((★ ⇒ ★) !ⁿ G-⇒) (ℕ ?ⁿ G-ℕ ⨾ i) =
    ⊥ⁿ (★ ⇒ ★) ⇨ C
    , ((((★ ⇒ ★) !) ⨟ (((ℕ `?)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      ((((★ ⇒ ★) !) ⨟ (ℕ `?)) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (β-proj-inj-badᶜ (λ ())) ⟩
      ((⊥ᶜ (★ ⇒ ★) ⇨ ℕ) ⨟ ⌊ i ⌋ⁱ)
      —→ᶜᶜ⟨ β-⊥Lᶜ (wtI i) ⟩
      (⊥ᶜ (★ ⇒ ★) ⇨ C)
      ∎ᶜᶜ))

  _i⨟s_ {C = C} (G !ⁿ g) (′ (⊥ⁿ ★ ⇨ C)) =
    ⊥ⁿ G ⇨ C
      , (((G !) ⨟ (⊥ᶜ ★ ⇨ C)
      —→ᶜᶜ⟨ β-!⊥ᶜ ⟩
      (⊥ᶜ G ⇨ C)
      ∎ᶜᶜ))

  _i⨟s_ (ℕ !ⁿ G-ℕ) (ℕ ?ⁿ G-ℕ ⨾ k ⨾!)
    with idℕ g⨟g k
  ... | m , id⨟k↠m =
    ‹ ℕ › m ⨾ G-ℕ !ⁿ
    , ((((ℕ !) ⨟ (((ℕ `?) ⨟ ⌊ k ⌋ᵍ) ⨟ (ℕ !)))
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      (((ℕ !) ⨟ ((ℕ `?) ⨟ ⌊ k ⌋ᵍ)) ⨟ (ℕ !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ β-assocLᶜ ⟩
      ((((ℕ !) ⨟ (ℕ `?)) ⨟ ⌊ k ⌋ᵍ) ⨟ (ℕ !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (ξ-⨟₁ᶜ β-proj-inj-okᶜ) ⟩
      (((idᶜ ℕ) ⨟ ⌊ k ⌋ᵍ) ⨟ (ℕ !))
      —↠ᶜᶜ⟨ multi-ξ-⨟₁ᶜᶜ id⨟k↠m ⟩
      (⌊ m ⌋ᵍ ⨟ (ℕ !))
      ∎ᶜᶜ))

  _i⨟s_ ((★ ⇒ ★) !ⁿ G-⇒) ((★ ⇒ ★) ?ⁿ G-⇒ ⨾ k ⨾!)
    with id★⇒★ g⨟g k
  ... | m , id⨟k↠m =
    ‹ (★ ⇒ ★) › m ⨾ G-⇒ !ⁿ
    , (((((★ ⇒ ★) !) ⨟ ((((★ ⇒ ★) `?) ⨟ ⌊ k ⌋ᵍ) ⨟ ((★ ⇒ ★) !)))
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      ((((★ ⇒ ★) !) ⨟ (((★ ⇒ ★) `?) ⨟ ⌊ k ⌋ᵍ)) ⨟ ((★ ⇒ ★) !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ β-assocLᶜ ⟩
      (((((★ ⇒ ★) !) ⨟ ((★ ⇒ ★) `?)) ⨟ ⌊ k ⌋ᵍ) ⨟ ((★ ⇒ ★) !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (ξ-⨟₁ᶜ β-proj-inj-okᶜ) ⟩
      (((idᶜ (★ ⇒ ★)) ⨟ ⌊ k ⌋ᵍ) ⨟ ((★ ⇒ ★) !))
      —↠ᶜᶜ⟨ multi-ξ-⨟₁ᶜᶜ id⨟k↠m ⟩
      (⌊ m ⌋ᵍ ⨟ ((★ ⇒ ★) !))
      ∎ᶜᶜ))

  _i⨟s_ {A = A} (ℕ !ⁿ G-ℕ) ((★ ⇒ ★) ?ⁿ G-⇒ ⨾ k ⨾!) =
    ⊥ⁿ A ⇨ ★
    , ((((ℕ !) ⨟ ((((★ ⇒ ★) `?) ⨟ ⌊ k ⌋ᵍ) ⨟ ((★ ⇒ ★) !)))
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      (((ℕ !) ⨟ (((★ ⇒ ★) `?) ⨟ ⌊ k ⌋ᵍ)) ⨟ ((★ ⇒ ★) !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ β-assocLᶜ ⟩
      ((((ℕ !) ⨟ ((★ ⇒ ★) `?)) ⨟ ⌊ k ⌋ᵍ) ⨟ ((★ ⇒ ★) !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (ξ-⨟₁ᶜ (β-proj-inj-badᶜ (λ ()))) ⟩
      (((⊥ᶜ ℕ ⇨ (★ ⇒ ★)) ⨟ ⌊ k ⌋ᵍ) ⨟ ((★ ⇒ ★) !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (β-⊥Lᶜ (wtG k)) ⟩
      ((⊥ᶜ ℕ ⇨ (★ ⇒ ★)) ⨟ ((★ ⇒ ★) !))
      —→ᶜᶜ⟨ β-⊥Lᶜ (⊢! G-⇒) ⟩
      (⊥ᶜ ℕ ⇨ ★)
      ∎ᶜᶜ))

  _i⨟s_ {A = A} ((★ ⇒ ★) !ⁿ G-⇒) (ℕ ?ⁿ G-ℕ ⨾ k ⨾!) =
    ⊥ⁿ A ⇨ ★
    , (((((★ ⇒ ★) !) ⨟ (((ℕ `?) ⨟ ⌊ k ⌋ᵍ) ⨟ (ℕ !)))
      —→ᶜᶜ⟨ β-assocLᶜ ⟩
      ((((★ ⇒ ★) !) ⨟ ((ℕ `?) ⨟ ⌊ k ⌋ᵍ)) ⨟ (ℕ !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ β-assocLᶜ ⟩
      (((((★ ⇒ ★) !) ⨟ (ℕ `?)) ⨟ ⌊ k ⌋ᵍ) ⨟ (ℕ !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (ξ-⨟₁ᶜ (β-proj-inj-badᶜ (λ ()))) ⟩
      (((⊥ᶜ (★ ⇒ ★) ⇨ ℕ) ⨟ ⌊ k ⌋ᵍ) ⨟ (ℕ !))
      —→ᶜᶜ⟨ ξ-⨟₁ᶜ (β-⊥Lᶜ (wtG k)) ⟩
      ((⊥ᶜ (★ ⇒ ★) ⇨ ℕ) ⨟ (ℕ !))
      —→ᶜᶜ⟨ β-⊥Lᶜ (⊢! G-ℕ) ⟩
      (⊥ᶜ (★ ⇒ ★) ⇨ ★)
      ∎ᶜᶜ))

  _i⨟s_ (‹ G › g ⨾ gnd !ⁿ) (idⁿ ★) =
    ‹ G › g ⨾ gnd !ⁿ
    , (((⌊ g ⌋ᵍ ⨟ (G !)) ⨟ (idᶜ ★))
      —→ᶜᶜ⟨ β-idRᶜ ⟩
      (⌊ g ⌋ᵍ ⨟ (G !))
      ∎ᶜᶜ)

  _i⨟s_ (‹ ℕ › g ⨾ G-ℕ !ⁿ) (ℕ ?ⁿ G-ℕ) =
    ＇ g
    , ((((⌊ g ⌋ᵍ ⨟ (ℕ !)) ⨟ (ℕ `?))
      —→ᶜᶜ⟨ β-assocRᶜ ⟩
      (⌊ g ⌋ᵍ ⨟ ((ℕ !) ⨟ (ℕ `?)))
      —→ᶜᶜ⟨ ξ-⨟₂ᶜ β-proj-inj-okᶜ ⟩
      (⌊ g ⌋ᵍ ⨟ idᶜ ℕ)
      —→ᶜᶜ⟨ β-idRᶜ ⟩
      ⌊ g ⌋ᵍ
      ∎ᶜᶜ))

  _i⨟s_ {C = C} (‹ ℕ › idℕ ⨾ G-ℕ !ⁿ) ((★ ⇒ ★) ?ⁿ G-⇒) =
    ⊥ⁿ ℕ ⇨ (★ ⇒ ★)
    , ((((idᶜ ℕ ⨟ (ℕ !)) ⨟ ((★ ⇒ ★) `?))
      —→ᶜᶜ⟨ β-assocRᶜ ⟩
      (idᶜ ℕ ⨟ ((ℕ !) ⨟ ((★ ⇒ ★) `?)))
      —→ᶜᶜ⟨ ξ-⨟₂ᶜ (β-proj-inj-badᶜ (λ ())) ⟩
      (idᶜ ℕ ⨟ (⊥ᶜ ℕ ⇨ (★ ⇒ ★)))
      —→ᶜᶜ⟨ β-idLᶜ ⟩
      (⊥ᶜ ℕ ⇨ (★ ⇒ ★))
      ∎ᶜᶜ))

  _i⨟s_ (‹ (★ ⇒ ★) › g ⨾ G-⇒ !ⁿ) ((★ ⇒ ★) ?ⁿ G-⇒) =
    ＇ g
    , ((((⌊ g ⌋ᵍ ⨟ ((★ ⇒ ★) !)) ⨟ ((★ ⇒ ★) `?))
      —→ᶜᶜ⟨ β-assocRᶜ ⟩
      (⌊ g ⌋ᵍ ⨟ (((★ ⇒ ★) !) ⨟ ((★ ⇒ ★) `?)))
      —→ᶜᶜ⟨ ξ-⨟₂ᶜ β-proj-inj-okᶜ ⟩
      (⌊ g ⌋ᵍ ⨟ idᶜ (★ ⇒ ★))
      —→ᶜᶜ⟨ β-idRᶜ ⟩
      ⌊ g ⌋ᵍ
      ∎ᶜᶜ))

  _i⨟s_ {C = C} (‹ (★ ⇒ ★) › id★⇒★ ⨾ G-⇒ !ⁿ) (ℕ ?ⁿ G-ℕ) =
    ⊥ⁿ (★ ⇒ ★) ⇨ ℕ
    , ((((idᶜ (★ ⇒ ★) ⨟ ((★ ⇒ ★) !)) ⨟ (ℕ `?))
      —→ᶜᶜ⟨ β-assocRᶜ ⟩
      (idᶜ (★ ⇒ ★) ⨟ (((★ ⇒ ★) !) ⨟ (ℕ `?)))
      —→ᶜᶜ⟨ ξ-⨟₂ᶜ (β-proj-inj-badᶜ (λ ())) ⟩
