module GTLC where

open import Agda.Builtin.Nat using (Nat; zero; suc)
open import Agda.Builtin.List using (List; []; _вИЈ_)

data Ty : Set where
  вДХ   : Ty
  вШЕ   : Ty
  _вЗТ_ : Ty вЖТ Ty вЖТ Ty

------------------------------------------------------------
-- Type Consistency
------------------------------------------------------------

infix 4 _~_

data _~_ : Ty вЖТ Ty вЖТ Set where
  ~-вДХ  : вДХ ~ вДХ
  ~-вШЕ : вШЕ ~ вШЕ
  вШЕ~вДХ : вШЕ ~ вДХ
  вДХ~вШЕ : вДХ ~ вШЕ
  вШЕ~вЗТ : вИА{A B} вЖТ A ~ вШЕ вЖТ вШЕ ~ B вЖТ вШЕ ~ (A вЗТ B)
  вЗТ~вШЕ : вИА{A B} вЖТ вШЕ ~ A вЖТ B ~ вШЕ вЖТ (A вЗТ B) ~ вШЕ
  ~-вЗТ  : вИА {A B C D} вЖТ C ~ A вЖТ B ~ D вЖТ (A вЗТ B) ~ (C вЗТ D)

~-sym : вИА {A B} вЖТ A ~ B вЖТ B ~ A
~-sym ~-вДХ = ~-вДХ
~-sym ~-вШЕ = ~-вШЕ
~-sym вШЕ~вДХ = вДХ~вШЕ
~-sym вДХ~вШЕ = вШЕ~вДХ
~-sym (вШЕ~вЗТ A~вШЕ вШЕ~B) = вЗТ~вШЕ (~-sym A~вШЕ) (~-sym вШЕ~B)
~-sym (вЗТ~вШЕ вШЕ~A B~вШЕ) = вШЕ~вЗТ (~-sym вШЕ~A) (~-sym B~вШЕ)
~-sym (~-вЗТ C~A B~D) = ~-вЗТ (~-sym C~A) (~-sym B~D)

mutual
  вШЕ~-ty : вИА A вЖТ вШЕ ~ A
  вШЕ~-ty вДХ = вШЕ~вДХ
  вШЕ~-ty вШЕ = ~-вШЕ
  вШЕ~-ty (A вЗТ B) = вШЕ~вЗТ (~вШЕ-ty A) (вШЕ~-ty B)

  ~вШЕ-ty : вИА A вЖТ A ~ вШЕ
  ~вШЕ-ty вДХ = вДХ~вШЕ
  ~вШЕ-ty вШЕ = ~-вШЕ
  ~вШЕ-ty (A вЗТ B) = вЗТ~вШЕ (вШЕ~-ty A) (~вШЕ-ty B)

------------------------------------------------------------
-- Type Precision
------------------------------------------------------------

infix 4 _вКС_
data _вКС_ : Ty вЖТ Ty вЖТ Set where
  вКС-вДХ : вДХ вКС вДХ
  вКС-вШЕ : вИА {A} вЖТ вШЕ вКС A
  вКС-вЗТ : вИА {A B C D} вЖТ A вКС C вЖТ B вКС D вЖТ (A вЗТ B) вКС (C вЗТ D)

вКС-refl : вИА {A} вЖТ A вКС A
вКС-refl {A = вДХ} = вКС-вДХ
вКС-refl {A = вШЕ} = вКС-вШЕ
вКС-refl {A = A вЗТ B} = вКС-вЗТ вКС-refl вКС-refl

Var : Set
Var = Nat

data Term : Set where
  `_    : Var вЖТ Term
  $_    : Nat вЖТ Term
  ∆Ы_вЗТ_  : Ty вЖТ Term вЖТ Term
  _¬Ј_   : Term вЖТ Term вЖТ Term

Ctx : Set
Ctx = List Ty

infix 4 _вИЛ_в¶В_

data _вИЛ_в¶В_ : Ctx вЖТ Var вЖТ Ty вЖТ Set where
  Z : вИА {ќУ A} вЖТ (A вИЈ ќУ) вИЛ zero в¶В A
  S : вИА {ќУ A B x} вЖТ ќУ вИЛ x в¶В A вЖТ (B вИЈ ќУ) вИЛ suc x в¶В A

infix 4 _вКҐ_в¶В_

data _вКҐ_в¶В_ : Ctx вЖТ Term вЖТ Ty вЖТ Set where
  вКҐ` : вИА {ќУ x A}
    вЖТ ќУ вИЛ x в¶В A
      ----------------
    вЖТ ќУ вКҐ ` x в¶В A

  вКҐ$ : вИА {ќУ n}
      ---------
    вЖТ ќУ вКҐ $ n в¶В вДХ

  вКҐ∆Ы : вИА {ќУ A N B}
    вЖТ (A вИЈ ќУ) вКҐ N в¶В B
      -----------------------
    вЖТ ќУ вКҐ ∆Ы A вЗТ N в¶В (A вЗТ B)

  вКҐ¬Ј : вИА {ќУ L M A AвА≤ B}
    вЖТ ќУ вКҐ L в¶В (A вЗТ B)
    вЖТ ќУ вКҐ M в¶В AвА≤ 
    вЖТ AвА≤ ~ A
      ----------------
    вЖТ ќУ вКҐ L ¬Ј M в¶В B

  вКҐ¬ЈвШЕ : вИА {ќУ L M A}
    вЖТ ќУ вКҐ L в¶В вШЕ
    вЖТ ќУ вКҐ M в¶В A
      ----------------
    вЖТ ќУ вКҐ L ¬Ј M в¶В вШЕ

infix 4 _вКСбµА_

data _вКСбµА_ : Term вЖТ Term вЖТ Set where
  вКС` : вИА {x}
    вЖТ ` x вКСбµА ` x

  вКС$ : вИА {n}
    вЖТ $ n вКСбµА $ n

  вКС∆Ы : вИА {A B N M}
    вЖТ A вКС B
    вЖТ N вКСбµА M
    вЖТ ∆Ы A вЗТ N вКСбµА ∆Ы B вЗТ M

  вКС¬Ј : вИА {L LвА≤ M MвА≤}
    вЖТ L вКСбµА LвА≤
    вЖТ M вКСбµА MвА≤
    вЖТ L ¬Ј M вКСбµА LвА≤ ¬Ј MвА≤
