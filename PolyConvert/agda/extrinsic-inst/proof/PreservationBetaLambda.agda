substбө—-[]бө— :
  (Пғ : Substбө—) (A T : Ty) вҶ’
  substбө— Пғ (A [ T ]бө—) вүЎ (substбө— (extsбө— Пғ) A) [ substбө— Пғ T ]бө—
substбө—-[]бө— Пғ A T =
  trans
    (substбө—-substбө— Пғ (singleTyEnv T) A)
    (trans
      (substбө—-cong env A)
      (sym (substбө—-substбө— (singleTyEnv (substбө— Пғ T)) (extsбө— Пғ) A)))
  where
    env :
      (X : TyVar) вҶ’
      substбө— Пғ (singleTyEnv T X) вүЎ
      substбө— (singleTyEnv (substбө— Пғ T)) (extsбө— Пғ X)
    env zero = refl
    env (suc X) = sym (open-renбө—-suc (Пғ X) (substбө— Пғ T))

substбө—-constTy : (Пғ : Substбө—) (Оә : Const) вҶ’
  substбө— Пғ (constTy Оә) вүЎ constTy Оә
substбө—-constTy Пғ (Оәв„• n) = refl

map-singleTyEnv-вӨҠбө— :
  (T : Ty) (О“ : Ctx) вҶ’
  map (substбө— (singleTyEnv T)) (вӨҠбө— О“) вүЎ О“
map-singleTyEnv-вӨҠбө— T [] = refl
map-singleTyEnv-вӨҠбө— T (A вҲ· О“) =
  congвӮӮ _вҲ·_ (open-renбө—-suc A T) (map-singleTyEnv-вӨҠбө— T О“)

cong-вҠўО”вҰӮ :
  вҲҖ {О” О”вҖІ ОЁ}{ОЈ : Store}{О“ : Ctx}{M : Term}{A : Ty} вҶ’
  О” вүЎ О”вҖІ вҶ’
  О” вҲЈ ОЁ вҲЈ ОЈ вҲЈ О“ вҠў M вҰӮ A вҶ’
  О”вҖІ вҲЈ ОЁ вҲЈ ОЈ вҲЈ О“ вҠў M вҰӮ A
cong-вҠўО”вҰӮ refl MвҠў = MвҠў

plainSubst-star-up :
  вҲҖ k Оұ X вҶ’
  UpValue (starImp (plainSubstVarFrom k (пҪҖ Оұ) X))
plainSubst-star-up zero Оұ zero = tag
plainSubst-star-up zero Оұ (suc X) = tagОҪ
plainSubst-star-up (suc k) Оұ zero = tagОҪ
plainSubst-star-up (suc k) Оұ (suc X)
  with plainSubstVarFrom k (пҪҖ Оұ) X | plainSubst-star-up k Оұ X
... | пјҮ Y | tagОҪ = tagОҪ
... | пҪҖ ОІ | tag = tag
... | вҖө О№ | tag = tag
... | A вҮ’ B | tag = tag

mutual
  substPlain-up-value :
    вҲҖ {p} k Оұ вҶ’
    UpValue p вҶ’
    UpValue (substImp (plainSubstVarFrom k (пҪҖ Оұ)) p)
  substPlain-up-value k Оұ (tagОҪ {X = X}) = plainSubst-star-up k Оұ X
  substPlain-up-value k Оұ tag = tag
  substPlain-up-value k Оұ (_вҶҰ_ {p = p} {q = q}) = _вҶҰ_
  substPlain-up-value k Оұ (`вҲҖ {p = p}) = `вҲҖ

  substPlain-down-value :
    вҲҖ {p} k Оұ вҶ’
    DownValue p вҶ’
    DownValue (substImp (plainSubstVarFrom k (пҪҖ Оұ)) p)
  substPlain-down-value k Оұ (_вҶҰ_ {p = p} {q = q}) = _вҶҰ_
  substPlain-down-value k Оұ (`вҲҖ {p = p}) = `вҲҖ
  substPlain-down-value k Оұ (ОҪ_ {B = B} {p = p}) =
    ОҪ_ {B = substбө— (plainSubstVarFrom k (пҪҖ Оұ)) B}
      {p = substImp (plainSubstVarFrom (suc k) (пҪҖ Оұ)) p}

mutual
  substPlain-reveal-value :
    вҲҖ {c} k Оұ вҶ’
    RevealValue c вҶ’
    RevealValue (substвҶ‘ (plainSubstVarFrom k (пҪҖ Оұ)) c)
  substPlain-reveal-value k Оұ (_вҶҰ_ {p = p} {q = q}) = _вҶҰ_
  substPlain-reveal-value k Оұ (`вҲҖ {c = c}) = `вҲҖ

  substPlain-conceal-value :
    вҲҖ {c} k Оұ вҶ’
    ConcealValue c вҶ’
    ConcealValue (substвҶ“ (plainSubstVarFrom k (пҪҖ Оұ)) c)
  substPlain-conceal-value k Оұ seal = seal
  substPlain-conceal-value k Оұ (_вҶҰ_ {p = p} {q = q}) = _вҶҰ_
  substPlain-conceal-value k Оұ (`вҲҖ {c = c}) = `вҲҖ

substPlain-value :
  вҲҖ {V} k Оұ вҶ’
  Value V вҶ’
  Value (substбө—бөҗ (plainSubstVarFrom k (пҪҖ Оұ)) V)
substPlain-value k Оұ (Жӣ A вҮ’ N) =
  Жӣ substбө— (plainSubstVarFrom k (пҪҖ Оұ)) A вҮ’
    substбө—бөҗ (plainSubstVarFrom k (пҪҖ Оұ)) N
substPlain-value k Оұ ($ Оә) = $ Оә
substPlain-value k Оұ (Оӣ N) =
  Оӣ substбө—бөҗ (plainSubstVarFrom (suc k) (пҪҖ Оұ)) N
substPlain-value k Оұ (vV вҮ‘ p) =
  substPlain-value k Оұ vV вҮ‘ substPlain-up-value k Оұ p
substPlain-value k Оұ (vV вҮ“ p) =
  substPlain-value k Оұ vV вҮ“ substPlain-down-value k Оұ p
substPlain-value k Оұ (vV вҶ‘ c) =
  substPlain-value k Оұ vV вҶ‘ substPlain-reveal-value k Оұ c
substPlain-value k Оұ (vV вҶ“ c) =
  substPlain-value k Оұ vV вҶ“ substPlain-conceal-value k Оұ c

data PlainList : ICtx вҶ’ Set where
  plain[] : PlainList []
  plainвҲ·_ : вҲҖ {ОҰ} вҶ’ PlainList ОҰ вҶ’ PlainList (plain вҲ· ОҰ)

length-plains : вҲҖ О” вҶ’ length (plains О” []) вүЎ О”
length-plains zero = refl
length-plains (suc О”) = cong suc (length-plains О”)

PlainList-plains :
  вҲҖ {ОҰ} вҶ’
  PlainList ОҰ вҶ’
  (О” : TyCtx) вҶ’
  plains (length (ОҰ ++ plains О” [])) [] вүЎ ОҰ ++ plains О” []
PlainList-plains plain[] О” rewrite length-plains О” = refl
PlainList-plains (plainвҲ· plainОҰ) О” =
  cong (plain вҲ·_) (PlainList-plains plainОҰ О”)

open-fresh-вҲҖвҠ‘-plains :
  вҲҖ {О” ОЁ}{ОЈ : Store}{ОҰ : ICtx}{A B : Ty}{p : Imp} вҶ’
  PlainList ОҰ вҶ’
  StoreWf О” ОЁ ОЈ вҶ’
  _вҲЈ_вҠў_вҰӮ_вҠ‘_
    ОЁ
    (plains (length (ОҰ ++ plain вҲ· plains О” [])) [])
    p A B вҶ’
  _вҲЈ_вҠў_вҰӮ_вҠ‘_
    (suc ОЁ)
    (plains (length (ОҰ ++ plains О” [])) [])
    (substPlainAtImp (length ОҰ) (пҪҖ (length ОЈ)) p)
    (substбө— (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ))) A)
    (substбө— (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ))) B)
open-fresh-вҲҖвҠ‘-plains
  {О” = О”} {ОЁ = ОЁ} {ОЈ = ОЈ} {ОҰ = ОҰ} {A = A} {B = B} {p = p}
  plainОҰ wfОЈ pвҠў =
  subst
    (О» О“ вҶ’
      _вҲЈ_вҠў_вҰӮ_вҠ‘_
        (suc ОЁ)
        О“
        (substPlainAtImp (length ОҰ) (пҪҖ (length ОЈ)) p)
        (substбө— (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ))) A)
        (substбө— (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ))) B))
    (sym (PlainList-plains plainОҰ О”))
    (open-fresh-вҲҖвҠ‘-prefix {ОҰ = ОҰ} wfОЈ
      (subst
        (О» О“ вҶ’ _вҲЈ_вҠў_вҰӮ_вҠ‘_ ОЁ О“ p A B)
        (PlainList-plains plainОҰ (suc О”))
        pвҠў))

openTerm-fresh-вҲҖ-prefix :
  вҲҖ {О” ОЁ}{ОЈ ОЈвӮҖ : Store}{ОҰ : ICtx}{О“ : Ctx}{M : Term}{A : Ty} вҶ’
  PlainList ОҰ вҶ’
  StoreWf О” ОЁ ОЈ вҶ’
  length (ОҰ ++ plain вҲ· plains О” []) вҲЈ ОЁ вҲЈ ОЈвӮҖ вҲЈ О“ вҠў M вҰӮ A вҶ’
  length (ОҰ ++ plains О” []) вҲЈ suc ОЁ вҲЈ
    substStoreбө— (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ))) ОЈвӮҖ вҲЈ
    map (substбө— (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ)))) О“ вҠў
    substбө—бөҗ (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ))) M вҰӮ
    substбө— (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ))) A
openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ (вҠў` h) = вҠў` (substLookup _ h)
openTerm-fresh-вҲҖ-prefix {ОҰ = ОҰ} plainОҰ wfОЈ (вҠўЖӣ wfA MвҠў) =
  вҠўЖӣ
    (substбө—-preserves-WfTy
      (WfTy-weakenЛў wfA (nвүӨ1+n _))
      (substWf-plain-prefix {ОҰ = ОҰ} wfОЈ))
    (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ (вҠўВ· LвҠў MвҠў) =
  вҠўВ· (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ LвҠў)
     (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
openTerm-fresh-вҲҖ-prefix {ОЈ = ОЈ} {ОЈвӮҖ = ОЈвӮҖ} {ОҰ = ОҰ} {О“ = О“} plainОҰ wfОЈ
  (вҠўОӣ {A = A} vM MвҠў) =
  вҠўОӣ
    (substPlain-value (suc (length ОҰ)) (length ОЈ) vM)
    (cong-вҠўвҰӮ
      (substStoreбө—-ext-вҹ°бө—
        (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ)))
        ОЈвӮҖ)
      (map-substбө—-вӨҠбө—
        (plainSubstVarFrom (length ОҰ) (пҪҖ (length ОЈ)))
        О“)
      refl
      refl
      (openTerm-fresh-вҲҖ-prefix {ОҰ = plain вҲ· ОҰ} (plainвҲ· plainОҰ) wfОЈ MвҠў))
openTerm-fresh-вҲҖ-prefix {ОҰ = ОҰ} plainОҰ wfОЈ
  (вҠўвҖў {B = B} {T = T} MвҠў wfB wfT) =
  cong-вҠўвҰӮ
    refl
    refl
    refl
    (sym (substбө—-[]бө— (plainSubstVarFrom (length ОҰ) (пҪҖ _)) B T))
    (вҠўвҖў
      (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
      (substбө—-preserves-WfTy
        (WfTy-weakenЛў wfB (nвүӨ1+n _))
        (TySubstWf-exts (substWf-plain-prefix {ОҰ = ОҰ} wfОЈ)))
      (substбө—-preserves-WfTy
        (WfTy-weakenЛў wfT (nвүӨ1+n _))
        (substWf-plain-prefix {ОҰ = ОҰ} wfОЈ)))
openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ (вҠў$ Оә) =
  cong-вҠўвҰӮ refl refl refl (sym (substбө—-constTy _ Оә)) (вҠў$ Оә)
openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ (вҠўвҠ• LвҠў op MвҠў) =
  вҠўвҠ• (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ LвҠў) op
      (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
openTerm-fresh-вҲҖ-prefix {ОҰ = ОҰ} plainОҰ wfОЈ (вҠўup {p = p} pвҠў MвҠў) =
  вҠўup
    (open-fresh-вҲҖвҠ‘-plains {ОҰ = ОҰ} plainОҰ wfОЈ pвҠў)
    (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
openTerm-fresh-вҲҖ-prefix {ОҰ = ОҰ} plainОҰ wfОЈ (вҠўdown {p = p} pвҠў MвҠў) =
  вҠўdown
    (open-fresh-вҲҖвҠ‘-plains {ОҰ = ОҰ} plainОҰ wfОЈ pвҠў)
    (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
openTerm-fresh-вҲҖ-prefix {ОЈ = ОЈ} {ОЈвӮҖ = ОЈвӮҖ} {ОҰ = ОҰ} plainОҰ wfОЈ
  (вҠўreveal cвҠў MвҠў) =
  вҠўreveal
    (substвҶ‘-wt
      (substWf-plain-prefix {ОҰ = ОҰ} wfОЈ)
      (wk-convвҶ‘ {ОЁвҖІ = suc _} (nвүӨ1+n _) вҠҶЛў-refl cвҠў))
    (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
openTerm-fresh-вҲҖ-prefix {ОҰ = ОҰ} plainОҰ wfОЈ (вҠўconceal cвҠў MвҠў) =
  вҠўconceal
    (substвҶ“-wt
      (substWf-plain-prefix {ОҰ = ОҰ} wfОЈ)
      (wk-convвҶ“ {ОЁвҖІ = suc _} (nвүӨ1+n _) вҠҶЛў-refl cвҠў))
    (openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ MвҠў)
openTerm-fresh-вҲҖ-prefix plainОҰ wfОЈ (вҠўblame в„“) = вҠўblame в„“

[]бөҖ-fresh-вҲҖ-wt :
  вҲҖ {О” ОЁ}{ОЈ : Store}{О“ : Ctx}{M : Term}{A : Ty} вҶ’
  StoreWf О” ОЁ ОЈ вҶ’
  suc О” вҲЈ ОЁ вҲЈ вҹ°бө— ОЈ вҲЈ вӨҠбө— О“ вҠў M вҰӮ A вҶ’
  О” вҲЈ suc ОЁ вҲЈ ОЈ вҲЈ О“ вҠў M [ пҪҖ (length ОЈ) ]бөҖ вҰӮ A [ пҪҖ (length ОЈ) ]бө—
[]бөҖ-fresh-вҲҖ-wt {О” = О”} {ОЈ = ОЈ} {О“ = О“} wfОЈ MвҠў =
  cong-вҠўО”вҰӮ (length-plains О”)
    (cong-вҠўвҰӮ
      (substStoreбө—-singleTyEnv-вҹ°бө— (пҪҖ (length ОЈ)) ОЈ)
      (map-singleTyEnv-вӨҠбө— (пҪҖ (length ОЈ)) О“)
      refl
      refl
      (openTerm-fresh-вҲҖ-prefix {О” = О”} {ОҰ = []} plain[] wfОЈ
        (cong-вҠўО”вҰӮ (sym (length-plains (suc О”))) MвҠў)))

