cong-вҠўвҶ‘ :
  вҲҖ {О” ОЁ}{ОЈ ОЈвҖІ : Store}{c cвҖІ : ConvвҶ‘}{A AвҖІ B BвҖІ : Ty} вҶ’
  ОЈ вүЎ ОЈвҖІ вҶ’
  c вүЎ cвҖІ вҶ’
  A вүЎ AвҖІ вҶ’
  B вүЎ BвҖІ вҶ’
  О” вҲЈ ОЁ вҲЈ ОЈ вҠў c вҰӮ A вҶ‘Лў B вҶ’
  О” вҲЈ ОЁ вҲЈ ОЈвҖІ вҠў cвҖІ вҰӮ AвҖІ вҶ‘Лў BвҖІ
cong-вҠўвҶ‘ refl refl refl refl cвҠў = cвҠў

cong-вҠўвҶ“ :
  вҲҖ {О” ОЁ}{ОЈ ОЈвҖІ : Store}{c cвҖІ : ConvвҶ“}{A AвҖІ B BвҖІ : Ty} вҶ’
  ОЈ вүЎ ОЈвҖІ вҶ’
  c вүЎ cвҖІ вҶ’
  A вүЎ AвҖІ вҶ’
  B вүЎ BвҖІ вҶ’
  О” вҲЈ ОЁ вҲЈ ОЈ вҠў c вҰӮ A вҶ“Лў B вҶ’
  О” вҲЈ ОЁ вҲЈ ОЈвҖІ вҠў cвҖІ вҰӮ AвҖІ вҶ“Лў BвҖІ
cong-вҠўвҶ“ refl refl refl refl cвҠў = cвҠў

plainSubstVarFrom-neq :
  вҲҖ X Y SвӮҒ T вҶ’
  X вүў Y вҶ’
  plainSubstVarFrom X SвӮҒ Y вүЎ plainSubstVarFrom X T Y
plainSubstVarFrom-neq zero zero SвӮҒ T XвүўY = вҠҘ-elim (XвүўY refl)
plainSubstVarFrom-neq zero (suc Y) SвӮҒ T XвүўY = refl
plainSubstVarFrom-neq (suc X) zero SвӮҒ T XвүўY = refl
plainSubstVarFrom-neq (suc X) (suc Y) SвӮҒ T XвүўY =
  cong (renameбө— suc)
    (plainSubstVarFrom-neq X Y SвӮҒ T (О» XвүЎY вҶ’ XвүўY (cong suc XвүЎY)))

plainSubstVarFrom-seal-self :
  вҲҖ X Оұ вҶ’
  plainSubstVarFrom X (пҪҖ Оұ) X вүЎ пҪҖ Оұ
plainSubstVarFrom-seal-self zero Оұ = refl
plainSubstVarFrom-seal-self (suc X) Оұ
  rewrite plainSubstVarFrom-seal-self X Оұ = refl

mutual
  convertвҶ‘At-wt :
    вҲҖ {О” ОЁ}{ОЈ : Store}{Оұ : Seal}{T B : Ty} вҶ’
    (Xбөӣ : TyVar) вҶ’
    ОЈ вҲӢЛў Оұ вҰӮ plainSubstVarFrom Xбөӣ T Xбөӣ вҶ’
    WfTy О” ОЁ (substбө— (plainSubstVarFrom Xбөӣ (пҪҖ Оұ)) B) вҶ’
    О” вҲЈ ОЁ вҲЈ ОЈ вҠў convertвҶ‘At Xбөӣ B Оұ вҰӮ
      substбө— (plainSubstVarFrom Xбөӣ (пҪҖ Оұ)) B вҶ‘Лў
      substбө— (plainSubstVarFrom Xбөӣ T) B
  convertвҶ‘At-wt {Оұ = Оұ} {B = пјҮ Y} X hОұ wfSrc with X вүҹ Y
  convertвҶ‘At-wt {Оұ = Оұ} {B = пјҮ .X} X hОұ wfSrc | yes refl =
    cong-вҠўвҶ‘ refl refl (sym (plainSubstVarFrom-seal-self X Оұ)) refl
      (вҠўвҶ‘-unseal hОұ)
  convertвҶ‘At-wt {Оұ = Оұ} {T = T} {B = пјҮ Y} X hОұ wfSrc | no XвүўY =
    cong-вҠўвҶ‘ refl refl refl (plainSubstVarFrom-neq X Y (пҪҖ Оұ) T XвүўY)
      (вҠўвҶ‘-id wfSrc)
  convertвҶ‘At-wt {B = пҪҖ ОІ} X hОұ wfSrc = вҠўвҶ‘-id wfSrc
  convertвҶ‘At-wt {B = вҖө О№} X hОұ wfSrc = вҠўвҶ‘-id wfSrc
  convertвҶ‘At-wt {B = вҳ…} X hОұ wfSrc = вҠўвҶ‘-id wfSrc
  convertвҶ‘At-wt {B = A вҮ’ B} X hОұ (wfвҮ’ wfA wfB) =
    вҠўвҶ‘-вҮ’ (convertвҶ“At-wt {B = A} X hОұ wfA)
          (convertвҶ‘At-wt {B = B} X hОұ wfB)
  convertвҶ‘At-wt {B = `вҲҖ A} X hОұ (wfвҲҖ wfA) =
    вҠўвҶ‘-вҲҖ (convertвҶ‘At-wt {B = A} (suc X) (renameLookupбө— suc hОұ) wfA)

  convertвҶ“At-wt :
    вҲҖ {О” ОЁ}{ОЈ : Store}{Оұ : Seal}{T B : Ty} вҶ’
    (Xбөӣ : TyVar) вҶ’
    ОЈ вҲӢЛў Оұ вҰӮ plainSubstVarFrom Xбөӣ T Xбөӣ вҶ’
    WfTy О” ОЁ (substбө— (plainSubstVarFrom Xбөӣ (пҪҖ Оұ)) B) вҶ’
    О” вҲЈ ОЁ вҲЈ ОЈ вҠў convertвҶ“At Xбөӣ B Оұ вҰӮ
      substбө— (plainSubstVarFrom Xбөӣ T) B вҶ“Лў
      substбө— (plainSubstVarFrom Xбөӣ (пҪҖ Оұ)) B
  convertвҶ“At-wt {Оұ = Оұ} {B = пјҮ Y} X hОұ wfSrc with X вүҹ Y
  convertвҶ“At-wt {Оұ = Оұ} {B = пјҮ .X} X hОұ wfSrc | yes refl =
    cong-вҠўвҶ“ refl refl refl (sym (plainSubstVarFrom-seal-self X Оұ))
      (вҠўвҶ“-seal hОұ)
  convertвҶ“At-wt {Оұ = Оұ} {T = T} {B = пјҮ Y} X hОұ wfSrc | no XвүўY =
    cong-вҠўвҶ“ refl refl (plainSubstVarFrom-neq X Y (пҪҖ Оұ) T XвүўY) refl
      (вҠўвҶ“-id wfSrc)
  convertвҶ“At-wt {B = пҪҖ ОІ} X hОұ wfSrc = вҠўвҶ“-id wfSrc
  convertвҶ“At-wt {B = вҖө О№} X hОұ wfSrc = вҠўвҶ“-id wfSrc
  convertвҶ“At-wt {B = вҳ…} X hОұ wfSrc = вҠўвҶ“-id wfSrc
  convertвҶ“At-wt {B = A вҮ’ B} X hОұ (wfвҮ’ wfA wfB) =
    вҠўвҶ“-вҮ’ (convertвҶ‘At-wt {B = A} X hОұ wfA)
          (convertвҶ“At-wt {B = B} X hОұ wfB)
  convertвҶ“At-wt {B = `вҲҖ A} X hОұ (wfвҲҖ wfA) =
    вҠўвҶ“-вҲҖ (convertвҶ“At-wt {B = A} (suc X) (renameLookupбө— suc hОұ) wfA)

------------------------------------------------------------------------
-- ОІ-Оӣ preservation
------------------------------------------------------------------------

preserve-ОІ-Оӣ :
  вҲҖ {О” ОЁ}{ОЈ : Store}{О“ : Ctx}{V : Term}{B T : Ty} вҶ’
  StoreWf О” ОЁ ОЈ вҶ’
  Value V вҶ’
  suc О” вҲЈ ОЁ вҲЈ вҹ°бө— ОЈ вҲЈ вӨҠбө— О“ вҠў V вҰӮ B вҶ’
  WfTy (suc О”) ОЁ B вҶ’
  WfTy О” ОЁ T вҶ’
  О” вҲЈ suc ОЁ вҲЈ ((length ОЈ , T) вҲ· ОЈ) вҲЈ О“ вҠў
    ((V [ пҪҖ (length ОЈ) ]бөҖ) вҶ‘ (convertвҶ‘ B (length ОЈ))) вҰӮ B [ T ]бө—
preserve-ОІ-Оӣ {О” = О”} {ОЁ = ОЁ} {ОЈ = ОЈ} {О“ = О“}
  {V = V} {B = B} {T = T} wfОЈ vV VвҠў wfB wfT =
  вҠўreveal cвҠў VopenвҠўвҶ‘
  where
    Оұ = length ОЈ

    wfОұ : WfTy О” (suc ОЁ) (пҪҖ Оұ)
    wfОұ = wfSeal (len<suc-StoreWf wfОЈ)

    VopenвҠў :
      О” вҲЈ suc ОЁ вҲЈ ОЈ вҲЈ О“ вҠў V [ пҪҖ Оұ ]бөҖ вҰӮ B [ пҪҖ Оұ ]бө—
    VopenвҠў = []бөҖ-fresh-вҲҖ-wt wfОЈ VвҠў

    VopenвҠўвҶ‘ :
      О” вҲЈ suc ОЁ вҲЈ ((Оұ , T) вҲ· ОЈ) вҲЈ О“ вҠў
        V [ пҪҖ Оұ ]бөҖ вҰӮ B [ пҪҖ Оұ ]бө—
    VopenвҠўвҶ‘ = wk-term вүӨ-refl (drop вҠҶЛў-refl) VopenвҠў

    wfBОұ : WfTy О” (suc ОЁ) (B [ пҪҖ Оұ ]бө—)
    wfBОұ =
      substбө—-preserves-WfTy
        (WfTy-weakenЛў wfB (nвүӨ1+n ОЁ))
        (singleTyEnv-Wf (пҪҖ Оұ) wfОұ)

    cвҠў :
      О” вҲЈ suc ОЁ вҲЈ ((Оұ , T) вҲ· ОЈ) вҠў
        convertвҶ‘ B Оұ вҰӮ B [ пҪҖ Оұ ]бө— вҶ‘Лў B [ T ]бө—
    cвҠў = convertвҶ‘At-wt {Оұ = Оұ} {T = T} {B = B} zero
      (ZвҲӢЛў refl refl)
      wfBОұ
