module GTLC where

open import Agda.Builtin.Nat using (Nat; zero; suc)
open import Agda.Builtin.List using (List; []; _вҲ·_)

data Ty : Set where
  в„•   : Ty
  вҳ…   : Ty
  _вҮ’_ : Ty вҶ’ Ty вҶ’ Ty

infix 4 _~_

data _~_ : Ty вҶ’ Ty вҶ’ Set where
  ~-в„•  : в„• ~ в„•
  ~-вҳ… : вҳ… ~ вҳ…
  вҳ…~в„• : вҳ… ~ в„•
  в„•~вҳ… : в„• ~ вҳ…
  вҳ…~вҮ’ : вҲҖ{A B} вҶ’ A ~ вҳ… вҶ’ вҳ… ~ B вҶ’ вҳ… ~ (A вҮ’ B)
  вҮ’~вҳ… : вҲҖ{A B} вҶ’ вҳ… ~ A вҶ’ B ~ вҳ… вҶ’ (A вҮ’ B) ~ вҳ…
  ~-вҮ’  : вҲҖ {A B C D} вҶ’ C ~ A вҶ’ B ~ D вҶ’ (A вҮ’ B) ~ (C вҮ’ D)

~-sym : вҲҖ {A B} вҶ’ A ~ B вҶ’ B ~ A
~-sym ~-в„• = ~-в„•
~-sym ~-вҳ… = ~-вҳ…
~-sym вҳ…~в„• = в„•~вҳ…
~-sym в„•~вҳ… = вҳ…~в„•
~-sym (вҳ…~вҮ’ A~вҳ… вҳ…~B) = вҮ’~вҳ… (~-sym A~вҳ…) (~-sym вҳ…~B)
~-sym (вҮ’~вҳ… вҳ…~A B~вҳ…) = вҳ…~вҮ’ (~-sym вҳ…~A) (~-sym B~вҳ…)
~-sym (~-вҮ’ C~A B~D) = ~-вҮ’ (~-sym C~A) (~-sym B~D)

infix 4 _вҠ‘_

data _вҠ‘_ : Ty вҶ’ Ty вҶ’ Set where
  вҠ‘-в„• : в„• вҠ‘ в„•
  вҠ‘-вҳ… : вҲҖ {A} вҶ’ вҳ… вҠ‘ A
  вҠ‘-вҮ’ : вҲҖ {A B C D} вҶ’ A вҠ‘ C вҶ’ B вҠ‘ D вҶ’ (A вҮ’ B) вҠ‘ (C вҮ’ D)

Var : Set
Var = Nat

data Term : Set where
  `_    : Var вҶ’ Term
  $_    : Nat вҶ’ Term
  Жӣ_вҮ’_  : Ty вҶ’ Term вҶ’ Term
  _В·_   : Term вҶ’ Term вҶ’ Term

Ctx : Set
Ctx = List Ty

infix 4 _вҲӢ_вҰӮ_

data _вҲӢ_вҰӮ_ : Ctx вҶ’ Var вҶ’ Ty вҶ’ Set where
  Z : вҲҖ {О“ A} вҶ’ (A вҲ· О“) вҲӢ zero вҰӮ A
  S : вҲҖ {О“ A B x} вҶ’ О“ вҲӢ x вҰӮ A вҶ’ (B вҲ· О“) вҲӢ suc x вҰӮ A

infix 4 _вҠў_вҰӮ_

data _вҠў_вҰӮ_ : Ctx вҶ’ Term вҶ’ Ty вҶ’ Set where
  вҠў` : вҲҖ {О“ x A}
    вҶ’ О“ вҲӢ x вҰӮ A
      ----------------
    вҶ’ О“ вҠў ` x вҰӮ A

  вҠў$ : вҲҖ {О“ n}
      ---------
    вҶ’ О“ вҠў $ n вҰӮ в„•

  вҠўЖӣ : вҲҖ {О“ A N B}
    вҶ’ (A вҲ· О“) вҠў N вҰӮ B
      -----------------------
    вҶ’ О“ вҠў Жӣ A вҮ’ N вҰӮ (A вҮ’ B)

  вҠўВ· : вҲҖ {О“ L M A AвҖІ B}
    вҶ’ О“ вҠў L вҰӮ (A вҮ’ B)
    вҶ’ О“ вҠў M вҰӮ AвҖІ 
    вҶ’ AвҖІ ~ A
      ----------------
    вҶ’ О“ вҠў L В· M вҰӮ B

  вҠўВ·вҳ… : вҲҖ {О“ L M A}
    вҶ’ О“ вҠў L вҰӮ вҳ…
    вҶ’ О“ вҠў M вҰӮ A
      ----------------
    вҶ’ О“ вҠў L В· M вҰӮ вҳ…

infix 4 _вҠ‘бөҖ_

data _вҠ‘бөҖ_ : Term вҶ’ Term вҶ’ Set where
  вҠ‘` : вҲҖ {x}
    вҶ’ ` x вҠ‘бөҖ ` x

  вҠ‘$ : вҲҖ {n}
    вҶ’ $ n вҠ‘бөҖ $ n

  вҠ‘Жӣ : вҲҖ {A B N M}
    вҶ’ A вҠ‘ B
    вҶ’ N вҠ‘бөҖ M
    вҶ’ Жӣ A вҮ’ N вҠ‘бөҖ Жӣ B вҮ’ M

  вҠ‘В· : вҲҖ {L LвҖІ M MвҖІ}
    вҶ’ L вҠ‘бөҖ LвҖІ
    вҶ’ M вҠ‘бөҖ MвҖІ
    вҶ’ L В· M вҠ‘бөҖ LвҖІ В· MвҖІ
